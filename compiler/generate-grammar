#!/usr/bin/env python
from subprocess import check_call
from functools import cache
import sys


ANTLR_PKG = "taihe.parse.antlr"
ANTLR_PATH = ANTLR_PKG.replace(".", "/")

# HACK: The parent module `taihe.parse` imports the code which will be generated by us soon.
# We directly import ANTLR-generated module, without initializing the parent module.
sys.path.insert(0, ANTLR_PATH)


@cache
def get_parser():
    from TaiheParser import TaiheParser

    return TaiheParser


def get_hint(attr_type):
    if attr_type.endswith("Lst"):
        return f"List['TaiheAST.{attr_type[:-3]}']"
    if attr_type.endswith("Opt"):
        return f"Optional['TaiheAST.{attr_type[:-3]}']"
    return f"'TaiheAST.{attr_type}'"


def get_attr_pairs(ctx):
    for attr_full_name, attr_ctx in ctx.__dict__.items():
        if attr_full_name[0].isupper() or attr_full_name.startswith("token"):
            yield attr_full_name.split("_", 1)


def generate_TaiheAST():
    ast = []
    ast.append(f"from dataclasses import dataclass\n")
    ast.append(f"from typing import Union, List, Optional\n")
    ast.append(f"\n")
    ast.append(f"from antlr4 import Token\n")
    ast.append(f"\n")
    ast.append(f"\n")
    ast.append(f"class TaiheAST:\n")
    ast.append(f"    @dataclass\n")
    ast.append(f"    class token:\n")
    ast.append(f"        text: str\n")
    ast.append(f"        line: Optional[int]\n")
    ast.append(f"        column: Optional[int]\n")
    ast.append(f"\n")
    parser = get_parser()
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        ctx = getattr(parser, node_type + "Context")(None)
        if rule_name.endswith("Uni"):
            ast.append(f"    {node_type} = Union[\n")
            for attr_type, attr_name in get_attr_pairs(ctx):
                attr_hint = get_hint(attr_type)
                ast.append(f"        {attr_hint},\n")
            ast.append(f"    ]\n")
        else:
            ast.append(f"    @dataclass\n")
            ast.append(f"    class {node_type}:\n")
            for attr_type, attr_name in get_attr_pairs(ctx):
                attr_hint = get_hint(attr_type)
                ast.append(f"        {attr_name}: {attr_hint}\n")
        ast.append(f"\n")
    ast.pop()
    with open(ANTLR_PATH + "/TaiheAST.py", "w") as file:
        file.writelines(ast)


def generate_TaiheVisitor():
    visitor = []
    visitor.append(f"from {ANTLR_PKG}.TaiheAST import TaiheAST\n")
    visitor.append(f"\n")
    visitor.append(f"\n")
    visitor.append(f"class TaiheVisitor:\n")
    visitor.append(f"    def visit(self, node):\n")
    visitor.append(
        f"        return getattr(self, 'visit_' + node.__class__.__name__)(node)\n"
    )
    visitor.append(f"\n")
    visitor.append(f"    def visit_token(self, node: TaiheAST.token):\n")
    visitor.append(f"        raise NotImplementedError\n")
    visitor.append(f"\n")
    parser = get_parser()
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        visitor.append(
            f"    def visit_{node_type}(self, node: TaiheAST.{node_type}):\n"
        )
        if rule_name.endswith("Uni"):
            ctx = getattr(parser, node_type + "Context")(None)
            for attr_type, attr_name in get_attr_pairs(ctx):
                visitor.append(f"        if isinstance(node, TaiheAST.{attr_type}):\n")
                visitor.append(f"            return self.visit_{attr_type}(node)\n")
        else:
            visitor.append(f"        raise NotImplementedError\n")
        visitor.append(f"\n")
    visitor.pop()
    with open(ANTLR_PATH + "/TaiheVisitor.py", "w") as file:
        file.writelines(visitor)


def run_antlr():
    args = [
        "antlr4",
        "-Dlanguage=Python3",
        "-no-listener",
        "Taihe.g4",
        "-o",
        ANTLR_PATH,
    ]
    check_call(args)


def main():
    run_antlr()
    generate_TaiheAST()
    generate_TaiheVisitor()


if __name__ == "__main__":
    main()
