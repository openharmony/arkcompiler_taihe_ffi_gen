#!/usr/bin/env python3

import sys
from functools import cache
from os import path
from subprocess import check_call

ANTLR_PKG = "taihe.parse.antlr"
ANTLR_PATH = path.join(*ANTLR_PKG.split("."))

# HACK: The parent module `taihe.parse` imports the code which will be generated by us soon.
# We directly import ANTLR-generated module, without initializing the parent module.
sys.path.insert(0, ANTLR_PATH)


@cache
def get_parser():
    from TaiheParser import TaiheParser

    return TaiheParser


def get_hint(attr_type):
    if attr_type.endswith("Lst"):
        return f'List["TaiheAST.{attr_type[:-3]}"]'
    if attr_type.endswith("Opt"):
        return f'Optional["TaiheAST.{attr_type[:-3]}"]'
    return f'"TaiheAST.{attr_type}"'


def get_attr_pairs(ctx):
    for attr_full_name, attr_ctx in ctx.__dict__.items():
        if not attr_full_name.startswith("_") and attr_full_name != "parser":
            yield attr_full_name.split("_", 1)


class Inspector:
    def __init__(self):
        self.parentCtx = None
        self.invokingState = None
        self.children = None
        self.start = None
        self.stop = None


def generate_TaiheAST():
    code = []
    code.append(f"from dataclasses import dataclass\n")
    code.append(f"from typing import Union, List, Optional\n")
    code.append(f"\n")
    code.append(f"from antlr4 import Token\n")
    code.append(f"\n")
    code.append(f"\n")
    code.append(f"class TaiheAST:\n")
    code.append(f"    @dataclass\n")
    code.append(f"    class token:\n")
    code.append(f"        text: str\n")
    code.append(f"        line: Optional[int] = None\n")
    code.append(f"        column: Optional[int] = None\n")
    code.append(f"\n")
    parser = get_parser()
    type_list = []
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        ctx_type = node_type + "Context"
        ctx_cls = getattr(parser, ctx_type)
        type_list.append((node_type, ctx_cls))
    for node_type, ctx_cls in type_list:
        subclasses = ctx_cls.__subclasses__()
        if subclasses:
            code.append(f"    {node_type} = Union[\n")
            for sub_cls in subclasses:
                sub_type = sub_cls.__name__
                attr_type = sub_type[:-7]
                attr_hint = get_hint(attr_type)
                type_list.append((attr_type, sub_cls))
                code.append(f"        {attr_hint},\n")
            code.append(f"    ]\n")
        else:
            ctx = ctx_cls(None, Inspector())
            code.append(f"    @dataclass\n")
            code.append(f"    class {node_type}:\n")
            for attr_type, attr_name in get_attr_pairs(ctx):
                attr_hint = get_hint(attr_type)
                code.append(f"        {attr_name}: {attr_hint}\n")
        code.append(f"\n")
    code.pop()
    with open(path.join(ANTLR_PATH, "TaiheAST.py"), "w") as file:
        file.writelines(code)


def generate_TaiheVisitor():
    code = []
    code.append(f"from {ANTLR_PKG}.TaiheAST import TaiheAST\n")
    code.append(f"\n")
    code.append(f"\n")
    code.append(f"class TaiheVisitor:\n")
    code.append(f"    def visit(self, node):\n")
    code.append(f"        node_type = node.__class__.__name__\n")
    code.append(f'        method_name = f"visit_{{node_type}}"\n')
    code.append(f"        method = getattr(self, method_name, self.generic_visit)\n")
    code.append(f"        method(node)\n")
    code.append(f"\n")
    code.append(f"    def generic_visit(self, node):\n")
    code.append(f"        for value in node.__dict__.values():\n")
    code.append(f"            if value is None:\n")
    code.append(f"                continue\n")
    code.append(f"            if isinstance(value, list):\n")
    code.append(f"                for item in value:\n")
    code.append(f"                    self.visit(item)\n")
    code.append(f"                continue\n")
    code.append(f"            self.visit(value)\n")
    code.append(f"\n")
    code.append(f"    def visit_token(self, node: TaiheAST.token):\n")
    code.append(f"        pass\n")
    stub = []
    stub.append(f"from {ANTLR_PKG}.TaiheAST import TaiheAST\n")
    stub.append(f"\n")
    stub.append(f"class TaiheVisitor:\n")
    stub.append(f"    def visit(self, node) -> None: ...\n")
    stub.append(f"    def generic_visit(self, node) -> None: ...\n")
    stub.append(f"    def visit_token(self, node: TaiheAST.token) -> None: ...\n")
    parser = get_parser()
    type_list = []
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        ctx_type = node_type + "Context"
        ctx_cls = getattr(parser, ctx_type)
        type_list.append((node_type, ctx_cls))
    for node_type, ctx_cls in type_list:
        subclasses = ctx_cls.__subclasses__()
        if subclasses:
            for sub_cls in subclasses:
                sub_type = sub_cls.__name__
                attr_type = sub_type[:-7]
                type_list.append((attr_type, sub_cls))
        else:
            stub.append(f"    def visit_{node_type}(self, node: TaiheAST.{node_type}) -> None: ...\n")
    with open(path.join(ANTLR_PATH, "TaiheVisitor.py"), "w") as file:
        file.writelines(code)
    with open(path.join(ANTLR_PATH, "TaiheVisitor.pyi"), "w") as file:
        file.writelines(stub)


def run_antlr():
    args = [
        "antlr4",
        "-Dlanguage=Python3",
        "-no-listener",
        "Taihe.g4",
        "-o",
        ANTLR_PATH,
    ]
    check_call(args)


def main():
    run_antlr()
    generate_TaiheAST()
    generate_TaiheVisitor()


if __name__ == "__main__":
    main()
