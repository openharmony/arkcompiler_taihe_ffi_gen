#!/usr/bin/env python
import sys
from functools import cache
from os import path
from subprocess import check_call

ANTLR_PKG = "taihe.parse.antlr"
ANTLR_PATH = path.join(*ANTLR_PKG.split("."))

# HACK: The parent module `taihe.parse` imports the code which will be generated by us soon.
# We directly import ANTLR-generated module, without initializing the parent module.
sys.path.insert(0, ANTLR_PATH)


@cache
def get_parser():
    from TaiheParser import TaiheParser

    return TaiheParser


def get_hint(attr_type):
    if attr_type.endswith("Lst"):
        return f'List["TaiheAST.{attr_type[:-3]}"]'
    if attr_type.endswith("Opt"):
        return f'Optional["TaiheAST.{attr_type[:-3]}"]'
    return f'"TaiheAST.{attr_type}"'


def get_attr_pairs(ctx):
    for attr_full_name, _attr_ctx in ctx.__dict__.items():
        if attr_full_name[0].isupper() or attr_full_name.startswith("token"):
            yield attr_full_name.split("_", 1)


def generate_TaiheAST():
    code = []
    code.append("from dataclasses import dataclass\n")
    code.append("from typing import Union, List, Optional\n")
    code.append("\n")
    code.append("from antlr4 import Token\n")
    code.append("\n")
    code.append("\n")
    code.append("class TaiheAST:\n")
    code.append("    @dataclass\n")
    code.append("    class token:\n")
    code.append("        text: str\n")
    code.append("        line: Optional[int] = None\n")
    code.append("        column: Optional[int] = None\n")
    code.append("\n")
    parser = get_parser()
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        ctx_type = node_type + "Context"
        ctx = getattr(parser, ctx_type)(None)
        if rule_name.endswith("Uni"):
            code.append(f"    {node_type} = Union[\n")
            for attr_type, _attr_name in get_attr_pairs(ctx):
                attr_hint = get_hint(attr_type)
                code.append(f"        {attr_hint},\n")
            code.append("    ]\n")
        else:
            code.append("    @dataclass\n")
            code.append(f"    class {node_type}:\n")
            for attr_type, attr_name in get_attr_pairs(ctx):
                attr_hint = get_hint(attr_type)
                code.append(f"        {attr_name}: {attr_hint}\n")
        code.append("\n")
    code.pop()
    with open(ANTLR_PATH + "/TaiheAST.py", "w") as file:
        file.writelines(code)


def generate_TaiheVisitor():
    code = []
    code.append(f"from {ANTLR_PKG}.TaiheAST import TaiheAST\n")
    code.append("\n")
    code.append("\n")
    code.append("class TaiheVisitor:\n")
    code.append("    def visit(self, node):\n")
    code.append("        node_type = node.__class__.__name__\n")
    code.append('        method_name = f"visit_{node_type}"\n')
    code.append("        method = getattr(self, method_name, self.generic_visit)\n")
    code.append("        return method(node)\n")
    code.append("\n")
    code.append("    def generic_visit(self, node):\n")
    code.append("        for value in node.__dict__.values():\n")
    code.append("            if value is None:\n")
    code.append("                continue\n")
    code.append("            if isinstance(value, list):\n")
    code.append("                for item in value:\n")
    code.append("                    self.visit(item)\n")
    code.append("                continue\n")
    code.append("            self.visit(value)\n")
    code.append("\n")
    code.append("    def visit_token(self, node: TaiheAST.token):\n")
    code.append("        pass\n")
    stub = []
    stub.append("from typing import Any\n")
    stub.append("\n")
    stub.append(f"from {ANTLR_PKG}.TaiheAST import TaiheAST\n")
    stub.append("\n")
    stub.append("class TaiheVisitor:\n")
    stub.append("    def visit(self, node) -> Any: ...\n")
    stub.append("    def generic_visit(self, node) -> Any: ...\n")
    stub.append("    def visit_token(self, node: TaiheAST.token) -> Any: ...\n")
    parser = get_parser()
    for rule_name in parser.ruleNames:
        node_type = rule_name[0].upper() + rule_name[1:]
        if not node_type.endswith("Uni"):
            stub.append(
                f"    def visit_{node_type}(self, node: TaiheAST.{node_type}) -> Any: ...\n"
            )
    with open(path.join(ANTLR_PATH, "TaiheVisitor.py"), "w") as file:
        file.writelines(code)
    with open(path.join(ANTLR_PATH, "TaiheVisitor.pyi"), "w") as file:
        file.writelines(stub)


def run_antlr():
    args = [
        "antlr4",
        "-Dlanguage=Python3",
        "-no-listener",
        "Taihe.g4",
        "-o",
        ANTLR_PATH,
    ]
    check_call(args)


def main():
    run_antlr()
    generate_TaiheAST()
    generate_TaiheVisitor()


if __name__ == "__main__":
    main()
