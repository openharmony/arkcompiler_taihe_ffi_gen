#!/usr/bin/env python3

from enum import Enum
import os
import shutil
import subprocess
from pathlib import Path
import argparse
from taihe.driver import CompilerInstance, CompilerInvocation


class CommandRunner:
    @staticmethod
    def run(command: list[Path | str]):
        print("+", *command)
        result = subprocess.run(command, check=True, text=True)
        return result


class CodeGenerator:
    def __init__(
        self,
        idl_dir: Path,
        output_dir: Path,
        gen_author: bool = False,
        gen_user: bool = False,
    ):
        self.idl_dir = idl_dir
        self.output_dir = output_dir
        self.gen_author = gen_author
        self.gen_user = gen_user

    def generate(self):
        invocation = CompilerInvocation(
            src_dirs=[self.idl_dir],
            out_dir=self.output_dir,
            gen_author=self.gen_author,
            gen_user=self.gen_user,
        )
        instance = CompilerInstance(invocation)
        if not instance.run():
            raise RuntimeError("Compilation error")


class DirectoryManager:
    @staticmethod
    def clean(directory: Path):
        if directory.exists():
            shutil.rmtree(directory)

    @staticmethod
    def create(directory: Path):
        directory.mkdir(parents=True, exist_ok=True)

    @staticmethod
    def copy(src_directory: Path, dst_directory: Path):
        if src_directory.exists():
            shutil.copytree(src_directory, dst_directory, dirs_exist_ok=True)


