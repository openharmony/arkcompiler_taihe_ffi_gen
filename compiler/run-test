class Compiler:
    def __init__(self, c_compiler: str, cxx_compiler: str):
        self.c_compiler = c_compiler
        self.cxx_compiler = cxx_compiler

    def compile(
        self,
        output_dir: Path,
        input_dir: Path,
        *include_dirs: Path,
        opt_level: str,
        warning_options: WarningOptions,
    ):
        output_files = []
        for input_file in input_dir.iterdir():
            name = input_file.name
            output_file = output_dir / f"{name}.o"
            if name.endswith(".c"):
                compiler = self.c_compiler
                std = "gnu11"
            else:
                compiler = self.cxx_compiler
                std = "gnu++17"
            command = [
                compiler,
                "-c",
                "-fvisibility=hidden",
                "-fPIC",
                f"-O{opt_level}",
                f"-std={std}",
                "-o",
                output_file,
                input_file,
            ]
            command.extend(warning_options.value)
            for include_dir in include_dirs:
                command.extend(["-I", include_dir])
            CommandRunner.run(command)
            output_files.append(output_file)
        return output_files


class Linker:
    def __init__(self, linker: str):
        self.linker = linker

    def link(
        self,
        output_file: Path,
        *input_files: Path,
        shared: bool,
        link_options: list[str],
    ):
        command = [self.linker, "-fPIC", "-o", output_file]
        for input_file in input_files:
            command.append(str(input_file))
        for link_option in link_options:
            command.append(str(link_option))
        if shared:
            command.append("-shared")
        CommandRunner.run(command)


class BuildPipeline:
    def __init__(self, base_dir: Path, target_dir: Path, c: str, cxx: str):
        self.base_dir = base_dir
        self.target_dir = target_dir
        self.compiler = Compiler(
            c_compiler=c,
            cxx_compiler=cxx,
        )
        self.linker = Linker(linker=cxx)

    def build(
        self,
        generate_only: bool,
        author_link_options: list[str],
        user_link_options: list[str],
        run_args: list[str],
        opt_level: str,
        warning_options: WarningOptions,
    ):
        target_path = Path(self.target_dir)

        idl_dir = target_path / "idl"

        author_dir = target_path / "author"
        author_include_dir = author_dir / "include"
        author_src_dir = author_dir / "src"
        author_generated_dir = target_path / "author_generated"
        author_generated_include_dir = author_generated_dir / "include"
        author_generated_src_dir = author_generated_dir / "src"

        user_dir = target_path / "user"
        user_include_dir = user_dir / "include"
        user_src_dir = user_dir / "src"
        user_generated_dir = target_path / "user_generated"
        user_generated_include_dir = user_generated_dir / "include"

        runtime_dir = self.base_dir / ".." / "runtime"
        runtime_include_dir = runtime_dir / "include"
        runtime_src_dir = runtime_dir / "src"

        build_dir = target_path / "build"
        build_runtime_src_dir = build_dir / "runtime" / "src"
        build_author_generated_src_dir = build_dir / "author_generated" / "src"
        build_author_src_dir = build_dir / "author" / "src"
        build_user_src_dir = build_dir / "user" / "src"

        so_file = build_dir / "libtest.so"
        elf_file = build_dir / "test"

        idl_dir = self.target_dir / "idl"
        author_generated_dir = self.target_dir / "author_generated"
        user_generated_dir = self.target_dir / "user_generated"
        build_dir = self.target_dir / "build"
        so_file = build_dir / "libtest.so"
        elf_file = build_dir / "test"

        DirectoryManager.clean(author_generated_dir)
        DirectoryManager.clean(user_generated_dir)
        DirectoryManager.clean(build_dir)

        print("Generating author codes...")
        CodeGenerator(idl_dir, author_generated_dir, gen_author=True).generate()

        if not generate_only:
            DirectoryManager.create(build_runtime_src_dir)
            DirectoryManager.create(build_author_generated_src_dir)
            DirectoryManager.create(build_author_src_dir)

            print("Compiling to dynamic link library...")
            self.linker.link(
                so_file,
                *self.compiler.compile(
                    build_runtime_src_dir,
                    runtime_src_dir,
                    runtime_include_dir,
                    opt_level=opt_level,
                    warning_options=warning_options,
                ),
                *self.compiler.compile(
                    build_author_src_dir,
                    author_generated_src_dir,
                    runtime_include_dir,
                    author_generated_include_dir,
                    opt_level=opt_level,
                    warning_options=warning_options,
                ),
                *self.compiler.compile(
                    build_author_src_dir,
                    author_src_dir,
                    runtime_include_dir,
                    author_generated_include_dir,
                    author_include_dir,
                    opt_level=opt_level,
                    warning_options=warning_options,
                ),
                shared=True,
                link_options=author_link_options,
            )

        print("Generating user codes...")
        CodeGenerator(idl_dir, user_generated_dir, gen_user=True).generate()

        if not generate_only:
            DirectoryManager.create(build_user_src_dir)

            print("Compiling to executable file...")
            self.linker.link(
                elf_file,
                so_file,
                *self.compiler.compile(
                    build_user_src_dir,
                    user_src_dir,
                    runtime_include_dir,
                    user_generated_include_dir,
                    user_include_dir,
                    opt_level=opt_level,
                    warning_options=warning_options,
                ),
                shared=False,
                link_options=user_link_options,
            )

        print("Running...")
        CommandRunner.run([elf_file, *run_args])


def main():
    parser = argparse.ArgumentParser(
        description="Build and run project from a target directory"
    )
    parser.add_argument(
        "target_directory",
        type=str,
        help="The target directory containing source files for the project",
    )
    parser.add_argument(
        "-g",
        "--generate-only",
        action="store_true",
        help="To generate source and header files and not to compile them",
    )
    parser.add_argument(
        "-a",
        "--author-link-options",
        type=str,
        nargs="+",
        action="extend",
        default=[],
    )
    parser.add_argument(
        "-u",
        "--user-link-options",
        type=str,
        nargs="+",
        action="extend",
        default=[],
    )
    parser.add_argument(
        "-r",
        "--run-args",
        type=str,
        nargs="+",
        action="extend",
        default=[],
    )
    parser.add_argument(
        "-O",
        "--optimization",
        type=str,
        nargs="?",
        default="0",
        const="",
        help="Optimization level for compilation",
    )
    parser.add_argument(
        "--clang-version",
        type=str,
        default=None,
        help="Clang version to use for compilation",
    )
    parser.add_argument(
        "-W",
        "--warning-options",
        type=str,
        choices=[w.name for w in WarningOptions],
        default=WarningOptions.base.name,
        help="Warning options for compilation",
    )

    args = parser.parse_args()

    if args.clang_version is not None:
        if not args.clang_version.isdigit():
            raise ValueError("Clang version must be a number")
        c = f"clang-{args.clang_version}"
        cxx = f"clang++-{args.clang_version}"
    else:
        c = "clang"
        cxx = "clang++"

    warning_options = WarningOptions[args.warning_options]

    pipeline = BuildPipeline(
        base_dir=Path(__file__).resolve().parent,
        target_dir=Path(args.target_directory),
        c=os.getenv("C", c),
        cxx=os.getenv("CXX", cxx),
    )
    pipeline.build(
        generate_only=args.generate_only,
        author_link_options=args.author_link_options,
        user_link_options=args.user_link_options,
        run_args=args.run_args,
        opt_level=args.optimization,
        warning_options=warning_options,
    )


if __name__ == "__main__":
    main()
