#!/usr/bin/bash -eu

shopt -s nullglob

set -o pipefail
BASEDIR=$(dirname $0)
CXX="${CXX:-clang++}"
C="${C:-clang}"

taihec() {
    PYTHONPATH="$BASEDIR" python -m taihe "$@"
}

rm -rf "$1"/build
mkdir -p "$1"/build

rm -rf "$1"/author
taihec -I "$1"/idl -O "$1"/author --author
cp -rf "$1"/impl/* "$1"/author
for file in "$1"/author/*.c; do
    name=$(basename "$file")
    "$C" -c -o "$1"/build/"$name".o "$file" -I "$BASEDIR"/../runtime/include
done
for file in "$1"/author/*.cpp; do
    name=$(basename "$file")
    "$CXX" -c -o "$1"/build/"$name".o "$file" -I "$BASEDIR"/../runtime/include
done
"$CXX" "$1"/build/*.o -shared -fPIC -o "$1"/build/libtest.so
rm -rf "$1"/build/*.o
echo "Dynamic link library is generated successfully."

rm -rf "$1"/user
taihec -I "$1"/idl -O "$1"/user --user
cp -rf "$1"/src/* "$1"/user
for file in "$1"/user/*.c; do
    name=$(basename "$file")
    "$C" -c -o "$1"/build/"$name".o "$file" -I "$BASEDIR"/../runtime/include
done
for file in "$1"/user/*.cpp; do
    name=$(basename "$file")
    "$CXX" -c -o "$1"/build/"$name".o "$file" -I "$BASEDIR"/../runtime/include
done
"$CXX" "$1"/build/*.o "$1"/build/libtest.so -o "$1"/build/test
rm -rf "$1"/build/*.o
echo "Excutable file is generated successfully, running..."

"$1"/build/test
