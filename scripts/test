#!/usr/bin/bash

# Test and report code coverage.

source "$(dirname "$0")/common_lib.sh"
init_py_env

# Add trap to ensure coverage is reported even if script exits early
trap "coverage combine && coverage report" EXIT

run-ani-tests() {
    echo "Running ANI tests..."
    # Sort tests by modification time, newest first
    for item in $(find ../test/ani_* ../cookbook/* -maxdepth 0 -type d -printf "%T@ %p\n" | sort -nr | cut -d' ' -f2-); do
        echo "Testing: $item"
        coverage run --parallel-mode ./run-test "$item" -ani
    done
}

run-core-tests() {
    echo "Running core tests..."
    coverage run --parallel-mode --module pytest

    # Test everything except "../test/ani_*"
    echo "Testing non-ANI tests..."
    for test_dir in $(find ../test/* -maxdepth 0 -type d -not -path "../test/ani_*" \
                           -and -not -path "../test/compiler" \
                           -and -not -path "../test/promise" \ # TODO: Depends on ANI
                           -and -not -path "../test/impl_test"); do
        echo "Testing: $test_dir"
        coverage run --parallel-mode ./run-test "$test_dir" --generate-and-compile -ani
    done
}

run-ani-tests
run-core-tests

# The coverage report will be generated by the EXIT trap
echo "Generating coverage report..."
