    "runtime/include/taihe/unit.abi.h",
    "runtime/include/taihe/unit.hpp",
    "runtime/include/taihe/vector.abi.h",
    "runtime/include/taihe/vector.hpp",
    "runtime/src/object.cpp",
    "runtime/src/runtime_ani.cpp",
    "runtime/src/runtime_napi.cpp",
    "runtime/src/string.cpp",

    # Build script
    "scripts/build",

    # Python build config
    "pyproject.toml",
    "setup.py",

    # Stdlib IDL
    "stdlib/taihe.platform.ani.taihe",

    # CMake
    "cmake/TaiheUtils.cmake",
    "cmake/TaiheWorkflows.cmake",
  ]
  script = "//arkcompiler/taihe_ffi_gen/scripts/build"
  args = [
    "--output",
    rebase_path("$target_out_dir/dist"),
    "--strip_version",
  ]
  outputs = [
    "$target_out_dir/dist/taihe-linux-x86_64.tar.gz",
    "$target_out_dir/dist/taihe-darwin-arm64.tar.gz",
    "$target_out_dir/dist/taihe-darwin-x86_64.tar.gz",
    "$target_out_dir/dist/taihe-windows-x86_64.tar.gz",
    "$target_out_dir/dist/taihe-linux-x86_64/version.txt",
    "$target_out_dir/dist/taihe-darwin-arm64/version.txt",
    "$target_out_dir/dist/taihe-darwin-x86_64/version.txt",
    "$target_out_dir/dist/taihe-windows-x86_64/version.txt",
  ]
}

ohos_copy("build_taihe_wrapper") {
  sources = [
    "$target_out_dir/dist/taihe-linux-x86_64.tar.gz",
    "$target_out_dir/dist/taihe-darwin-arm64.tar.gz",
    "$target_out_dir/dist/taihe-darwin-x86_64.tar.gz",
    "$target_out_dir/dist/taihe-windows-x86_64.tar.gz"
  ]
  outputs = [ "$root_build_dir/obj/arkcompiler/taihe_ffi_gen/taihe_repo/{{source_file_part}}" ]
  deps = [ ":build_taihe" ]
}

if (sdk_build_arkts) {
  action("copy_taihe_out") {
    build_taihe_out_dir = get_label_info("build_taihe", "target_out_dir")
    parent_build_taihe_out_dir = get_path_info(build_taihe_out_dir, "dir")

    sources = [
      "$parent_build_taihe_out_dir/dist/taihe-darwin-arm64/version.txt",
      "$parent_build_taihe_out_dir/dist/taihe-darwin-x86_64/version.txt",
      "$parent_build_taihe_out_dir/dist/taihe-linux-x86_64/version.txt",
      "$parent_build_taihe_out_dir/dist/taihe-windows-x86_64/version.txt",
    ]

    script = "//arkcompiler/taihe_ffi_gen/scripts/process_sdk_files"
    args = [
      "--input_dir",
      rebase_path("${parent_build_taihe_out_dir}/dist"),
      "--output_dir",
      rebase_path("$target_out_dir/tmp_taihe"),
    ]
    outputs = [
      "$target_out_dir/tmp_taihe/taihe-linux-x86_64",
      "$target_out_dir/tmp_taihe/taihe-windows-x86_64",
      "$target_out_dir/tmp_taihe/taihe-darwin-arm64",
      "$target_out_dir/tmp_taihe/taihe-darwin-x86_64",
    ]
    deps = [ ":build_taihe" ]
  }

  if (current_toolchain == "//build/toolchain/mac:clang_x64") {
    ohos_copy("copy_taihe_tools") {
      sources = [ "//arkcompiler/taihe_ffi_gen/LICENSE" ]
      outputs = [ target_out_dir + "/$target_name" + "/taihe" ]
      module_source_dir = target_out_dir + "/$target_name"
      module_install_name = ""
      part_name = "taihe_ffi_gen"
      subsystem_name = "arkcompiler"
    }
  } else {
    ohos_copy("copy_taihe_tools") {
      deps = [ ":copy_taihe_out" ]
      if (current_toolchain == "//build/toolchain/linux:clang_x64") {
        sources = [ "$target_out_dir/tmp_taihe/taihe-linux-x86_64" ]
      } else if (current_toolchain == "//build/toolchain/mingw:mingw_x86_64") {
        sources = [ "$target_out_dir/tmp_taihe/taihe-windows-x86_64" ]
      } else if (current_toolchain == "//build/toolchain/mac:clang_arm64") {
        sources = [ "$target_out_dir/tmp_taihe/taihe-darwin-arm64" ]
      } else if (current_toolchain == "//build/toolchain/mac:clang_x64") {
        sources = [ "$target_out_dir/tmp_taihe/taihe-darwin-x86_64" ]
      }
      outputs = [ target_out_dir + "/$target_name" + "/taihe" ]
      module_source_dir = target_out_dir + "/$target_name"
      module_install_name = ""
      part_name = "taihe_ffi_gen"
      subsystem_name = "arkcompiler"
    }
  }
}
