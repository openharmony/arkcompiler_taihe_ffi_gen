import("//build/ohos.gni")
import("//build/ohos/sdk/sdk.gni")

action("build_taihe") {
  inputs = [
    # compiler/
    "compiler/Taihe.g4",
    "compiler/build.py",
    "compiler/taihe/__init__.py",
    "compiler/taihe/cli/__init__.py",
    "compiler/taihe/cli/compiler.py",
    "compiler/taihe/cli/tryit.py",
    "compiler/taihe/codegen/__init__.py",
    "compiler/taihe/codegen/abi/__init__.py",
    "compiler/taihe/codegen/abi/analyses.py",
    "compiler/taihe/codegen/abi/attributes.py",
    "compiler/taihe/codegen/abi/gen_abi.py",
    "compiler/taihe/codegen/abi/gen_impl.py",
    "compiler/taihe/codegen/abi/mangle.py",
    "compiler/taihe/codegen/abi/options.py",
    "compiler/taihe/codegen/abi/writer.py",
    "compiler/taihe/codegen/ani/__init__.py",
    "compiler/taihe/codegen/ani/analyses.py",
    "compiler/taihe/codegen/ani/attributes.py",
    "compiler/taihe/codegen/ani/gen_ani.py",
    "compiler/taihe/codegen/ani/gen_sts.py",
    "compiler/taihe/codegen/ani/options.py",
    "compiler/taihe/codegen/ani/writer.py",
    "compiler/taihe/codegen/cpp/__init__.py",
    "compiler/taihe/codegen/cpp/analyses.py",
    "compiler/taihe/codegen/cpp/gen_common.py",
    "compiler/taihe/codegen/cpp/gen_impl.py",
    "compiler/taihe/codegen/cpp/gen_user.py",
    "compiler/taihe/codegen/napi/__init__.py",
    "compiler/taihe/codegen/napi/analyses.py",
    "compiler/taihe/codegen/napi/attributes.py",
    "compiler/taihe/codegen/napi/gen_dts.py",
    "compiler/taihe/codegen/napi/gen_napi.py",
    "compiler/taihe/codegen/napi/gen_ts.py",
    "compiler/taihe/codegen/napi/writer.py",
    "compiler/taihe/driver/__init__.py",
    "compiler/taihe/driver/backend.py",
    "compiler/taihe/driver/contexts.py",
    "compiler/taihe/driver/options.py",
    "compiler/taihe/driver/toolchain.py",
    "compiler/taihe/parse/__init__.py",
    "compiler/taihe/parse/antlr/__init__.py",
    "compiler/taihe/parse/ast_generation.py",
    "compiler/taihe/parse/convert.py",
    "compiler/taihe/semantics/__init__.py",
    "compiler/taihe/semantics/analysis.py",
    "compiler/taihe/semantics/attributes.py",
    "compiler/taihe/semantics/declarations.py",
    "compiler/taihe/semantics/format.py",
    "compiler/taihe/semantics/types.py",
    "compiler/taihe/semantics/visitor.py",
    "compiler/taihe/utils/__init__.py",
    "compiler/taihe/utils/analyses.py",
    "compiler/taihe/utils/build_metadata.py",
    "compiler/taihe/utils/diagnostics.py",
    "compiler/taihe/utils/exceptions.py",
    "compiler/taihe/utils/logging.py",
    "compiler/taihe/utils/outputs.py",
    "compiler/taihe/utils/resources.py",
    "compiler/taihe/utils/sources.py",
    "compiler/tests/test_mangler.py",
    "compiler/tests/test_resources.py",
    "compiler/tests/test_semantic_error.py",

