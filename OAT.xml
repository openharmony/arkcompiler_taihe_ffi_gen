<configuration>
    <oatconfig>
        <licensefile></licensefile>
        <policylist>
            <policy name="projectPolicy" desc="">
                <policyitem type="compatibility" name="Apache" path=".*" desc=""/>
            </policy>
        </policylist>

        <filefilterlist>
            <filefilter name="defaultFilter" desc="Files not to check">
                <filteritem type="filename" name="uv.lock|poetry.lock|package-lock.json" desc="Lock files"/>
                <filteritem type="filename" name=".coveragerc" desc="Config files"/>
                <filteritem type="filepath" name=".vscode/.*|.idea/.*" desc="IDE config"/>
                <filteritem type="filename" name="__pycache__" desc="Python cache"/>
                <filteritem type="filename" name=".cache" desc="Cache directory"/>
                <filteritem type="filename" name="*.iml|*.json|*.txt|*.png|*.pdf" desc="desc files"/>
                <filteritem type="filepath" name=".*/docs/.*" desc="Docs files"/>
                <filteritem type="filepath" name=".*/cookbook/.*" desc="Cookbook files"/>
                <filteritem type="filepath" name=".*/test/xml/data/.*" desc="Test data files"/>
            </filefilter>
        </filefilterlist>
    </oatconfig>
</configuration>
