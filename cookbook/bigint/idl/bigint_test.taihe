@!sts_inject("""
export function GetNumfromBigint(b : BigInt) : long {
    let array : Array<long> = new Array<long>(0);
    let tmp : BigInt = b;
    while (tmp !== 0n) {
        let big = BigInt.asIntN(64, tmp);
        let lg : long = big.getLong();
        array.push(lg);
        tmp = tmp >> 64n;
    }
    array.reverse();
    let in : long[] = new long[array.length];
    for (let i = 0; i < array.length; i++) {
        in[i] = array[i];
        console.info("array:" + in[i]);
    }
    return getNumfromBigint(in);
}

export function GenBigint(lg : long[]) : BigInt {
    let array : long[] = genBigint(lg);
    let big: BigInt = 0n;
    for (let i = 0; i < array.length; i++) {
        let tmp: BigInt = new BigInt(array[i]);
        big = (big << 64n) | tmp;
    }
    return big;
}
""")

function getNumfromBigint(a : Array<i64>) : i64;
function genBigint(a : Array<i64>) : Array<i64>;