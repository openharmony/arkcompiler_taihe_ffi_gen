use foo;  // Error: PackageNotExist
use example.foo as foobar;  // OK
use example.bar as foobar;  // Error: PackageNameConflict
use example.bar;  // OK

from example.foobar use Foo;  // Error: PackageNotExist
from example.bar use Foo as Foobar;  // Error: SymbolNotExist
from example.bar use Bar as Foobar;  // OK
from example.foo use Foo as Foobar; // Error: SymbolConflict
from example.bar use Bar;  // OK

enum BadEnum1 {
    A;
    B = -1;
    C;
}  // Error: EnumValueConflict

enum GoodEnum1 {
    A;
    B;
    C = if (7 << 1 + 1) + (3 * 3 - 2 & 11) == 31 && 1 + 1 == 2 then 42 else 10;
    D;
}  // OK

function f(a: mut BadEnum1, a: i32): ();

struct BadStructA {
    b: BadStructB;
}
struct BadStructB {
    c: BadStructC;
}
struct BadStructC {
    a: BadStructA;
}  // Error: RecursiveInclusion

struct GoodStructA {
    b: GoodStructB;
}  // OK
struct GoodStructB {
    n: i32;
}  // OK

