// Use Packages

use example.nonexist as nonexist;  // PackageNotExistError

use example.foo as foobar;
use example.bar as foobar;  // UsingPackageConflictError

use example.bar as bar; // OK

// Use Symbols

from example.nonexist use XXX, YYY;  // PackageNotExistError

from example.bar use Nonexist as MyNonexist;  // DeclNotExistError

from example.foo use func as my_func; // NotATypeError

from example.bar use Bar as Foobar;
from example.foo use Foo as Foobar; // UsingTypeConflictError

from example.bar use Bar;  // OK

// Structs

struct UserTypes {
    s: nonexist.Baz;  // Should no error
    t: MyNonexist;  // Should no error

    u: example.unimported.Type;  // PackageNotInScopeError
    v: UnimportedType;  // DeclNotInScopeError
    w: bar.Foo;  // DeclNotExistError

    x: Bar.Type;  // NotAPackageError
    y: bar;  // NotADeclarationError
    z: bar.func;  // NotATypeError
}

struct BadStruct {}

struct BadStruct {  // DeclConflictError
    a: i32;
    a: i32;  // DeclConflictError
}

struct RecursiveStructA {
    b: RecursiveStructB;
}

struct RecursiveStructB {
    c: RecursiveStructC;
}

struct RecursiveStructC {
    a: RecursiveStructA;  // RecursiveInclusion
}

struct GoodStructA {
    b: GoodStructB;  // OK
}

struct GoodStructB {
    n: i32;
}

// Enums

enum BadEnum {
    A;
    A = -1;  // DeclConflictError
    B;  // EnumValueCollisionError
}

enum GoodEnum {
    A;
    B;
    C = if (7 << 1 + 1) + (3 * 3 - 2 & 11) == 31 && 1 + 1 == 2 then 42 else 10;  // OK (42)
    D;
}

// Functions

function bad_func_1(a: mut GoodEnum): ();  // QualifierError

function bad_func_2(a: i32, a: i32): ();  // SymbolConflictError

function inner(): ();  // SymbolConflictWithNamespaceError

function good_func_1(a: i32, b: mut Bar): (String, String);  // OK

// Interfaces

interface RecursiveIfaceA: RecursiveIfaceB {}

interface RecursiveIfaceB: RecursiveIfaceC {}

interface RecursiveIfaceC: RecursiveIfaceA {}  // RecursiveExtension

interface BadIface: i32 {  // ExtensTypeError
    function a(x: String): ();
    function a(x: i32): ();  // SymbolConflictError
}
