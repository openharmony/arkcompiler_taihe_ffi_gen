// Use Packages

use foo;  // PackageNotExistError

use example.foo as foobar;  // OK

use example.bar as foobar;  // UsingPackageConflictError

use example.bar;  // OK

use example.baz as baz;  // PackageNotExistError

// Use Symbols

from example.foobar use XXX, YYY;  // PackageNotExistError

from example.bar use Foo as ABC;  // SymbolNotExistError

from example.bar use Bar as Foobar;
from example.foo use Foo as Foobar; // UsingTypeConflictError

from example.bar use Bar;  // OK

// Others

function test(): ();
struct test {}  // SymbolConflictError

// Structs

struct BadStruct1 {
    x: UnimportedType;  // SymbolNotImportedError
    y: unimported.package.Type;  // PackageNotImportedError
    z: example.bar.Foo;  // SymbolNotExistError
}

struct BadStruct2 {
    x: i32;
    x: i32;  // SymbolConflictError
}

struct BadStruct3A {
    b: BadStruct3B;
}

struct BadStruct3B {
    c: BadStruct3C;
}

struct BadStruct3C {
    a: BadStruct3A;  // RecursiveInclusion
}

struct GoodStruct1A {
    b: GoodStruct1B;  // OK
}

struct GoodStruct1B {
    n: i32;
}

// Enums

enum BadEnum1 {
    A;
    B = -1;
    C;  // EnumValueCollisionError
}

enum BadEnum2 {
    A;
    A;  // SymbolConflictError
}

enum GoodEnum1 {
    A;
    B;
    C = if (7 << 1 + 1) + (3 * 3 - 2 & 11) == 31 && 1 + 1 == 2 then 42 else 10;  // OK (42)
    D;
}

// Functions

function bad_func_1(a: mut GoodEnum1): ();  // QualifierError

function bad_func_2(a: i32, a: i32): ();  // SymbolConflictError

function good_func_1(a: i32, b: mut Bar): (String, String);  // OK

function a(): ();  // SymbolConflictWithNamespaceError
