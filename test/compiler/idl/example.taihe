// use foo;  // Error: PackageNotExist
use example.foo as foobar;  // OK
// use example.bar as foobar;  // Error: PackageNameConflict
use example.bar;  // OK

// from example.foobar use Foo;  // Error: PackageNotExist
// from example.bar use Foo as Foobar;  // Error: SymbolNotExist
from example.bar use Bar as Foobar;  // OK
// from example.foo use Foo as Foobar; // Error: SymbolConflict
from example.foo use Foo;  // OK

// enum BadEnum1 {
