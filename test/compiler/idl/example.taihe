// Use Packages

use foo;  // PackageNotExistError

use example.foo as foobar;  // OK

use example.bar as foobar;  // PackageNameConflictError

use example.bar;  // OK

// Use Symbols

from example.foobar use Foo;  // PackageNotExistError

from example.bar use Foo;  // SymbolNotExistError

from example.bar use Bar as Foobar;
from example.foo use Foo as Foobar; // SymbolConflictError

from example.bar use Bar;  // OK

// Structs

struct BadStruct1 {
    x: UnimportedType;  // SymbolNotImportedError
    y: unimported.package.Type;  // PackageNotImportedError
    z: example.bar.Foo;  // SymbolNotExistError
}

struct BadStruct2 {
    x: i32;
    x: i32;
}  // SymbolConflictError

struct BadStruct3A {
    b: BadStruct3B;
}
struct BadStruct3B {
    c: BadStruct3C;
}
struct BadStruct3C {
    a: BadStruct3A;
}  // RecursiveInclusion

struct GoodStruct1A {
    b: GoodStructB;
}  // OK
struct GoodStruct1B {
    n: i32;
}  // OK

// Enums

enum BadEnum1 {
    A;
    B = -1;
    C;
}  // EnumValueCollisionError

enum BadEnum2 {
    A;
    A;
}  // SymbolConflictError

enum GoodEnum1 {
    A;
    B;
    C = if (7 << 1 + 1) + (3 * 3 - 2 & 11) == 31 && 1 + 1 == 2 then 42 else 10;
    D;
}  // OK

// Functions

function bad_func_1(a: mut GoodEnum1): ();  // QualifierError

function bad_func_2(a: i32, a: i32): ();  // SymbolConflictError

function good_func_1(a: i32, b: mut Bar): (String, String);  // OK

