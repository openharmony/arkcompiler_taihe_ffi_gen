// Use Packages

use example.bar as bar;  // OK

use example.nonexist as nonexist;  // PackageNotExistError

use example.foo as foobar;
use example.bar as foobar;  // DeclConflictError

// Use Symbols

from example.nonexist use XXX, YYY;  // PackageNotExistError

from example.bar use Bar;  // OK

from example.foo use func as my_func;  // NotATypeError

from example.foo use Nonexist as MyNonexist;  // DeclNotExistError

from example.bar use Bar as Foobar;
from example.foo use Foo as Foobar;  // DeclConflictError

// Structs

struct ResolveTypesTester {
    a: unimported.Type;  // PackageNotInScopeError
    b: Bar.Type;  // PackageNotInScopeError
    c: nonexist.Baz;  // Nothing should be reported here
    d: bar.Bar;  // OK
    e: bar.func;  // NotATypeError
    f: bar.Foo;  // DeclNotExistError

    u: GoodStruct;  // OK
    v: good_func;  // NotATypeError
    w: Unimported;  // DeclNotInScopeError
    x: bar;  // DeclNotInScopeError
    y: MyNonexist;  // Nothing should be reported here
    z: Bar;  // OK
}

struct Foobar {}  // DeclConflictError

struct BadStruct {}

struct BadStruct {  // DeclConflictError
    a: i32;
    a: i32;  // DeclConflictError
    b: TestIface;  // StructFieldTypeError
    c: MyNonexist;  // Nothing should be reported here
}

struct RecursiveStructA {
    b: RecursiveStructB;
}

struct RecursiveStructB {
    c: RecursiveStructC;
}

struct RecursiveStructC {
    a: RecursiveStructA;  // RecursiveInclusion
}

struct GoodStruct {
    n: i32;
}

// Enums

enum BadEnum {
    A;
    A = -1;  // DeclConflictError
}

enum GoodEnum {
    A;
    B;
    C = if (7 << 1 + 1) + (3 * 3 - 2 & 11) == 31 && 1 + 1 == 2 then 42 else 10;  // OK (should equal to 42)
    D;  // should be 43
}

// Functions

function foobar(): void;  // DeclConflictError

function inner(): void;  // SymbolConflictWithNamespaceError

function bad_func(a: i32, a: i32): void;  // DeclConflictError

function good_func(a: i32, b: Bar): String;  // OK

// Interfaces

interface TestIface {}

interface BadIface
    : i32  // ExtensTypeError
    , TestIface
    , TestIface  // DuplicateExtendsWarn
    , MyNonexist  // Nothing should be reported here
{
    function a(x: String): void;
    function a(x: i32): void;  // DeclConflictError
    function b(x: i32, x: i32): void;  // DeclConflictError
}

interface RecursiveIfaceA: RecursiveIfaceB {}

interface RecursiveIfaceB: RecursiveIfaceAlias {}  // RecursiveExtension

type RecursiveIfaceAlias = RecursiveIfaceA;

type RecursiveAliasA = RecursiveAliasB;
type RecursiveAliasB = RecursiveAliasA;

type AliasTestA = AliasTestB;
type AliasTestB = String;
