@!lib("my_module_a.so")

@!namespace("my_module_a", "ns1")
function Funtest(s: Color): String;
enum Color: String {
    RED = "Red",
    GREEN = "Green",
    BLUE = "Blue",
}
function noo(): void;

interface IBase {
@!ts_inject_into_interface("add(a: number, b: number): number;")
    @get getName(): String;
    @set setName(s: String): void;
    getId(): String;
    setId(s: String): void;
}

function makeIBase(id: String): IBase;
function bar(): void;

@class
interface CTest{
@!ts_inject_into_class("""mul(a: number, b: number): number {
    return a * b;
}
""")
    @get getName(): String;
    @set setName(s: String): void;
    add(a: i32, b: i32): i32;
}

@ctor("CTest")
function createCTest(id: i32): CTest;

function changeCTest(a: CTest): CTest;

@static("CTest")
function multiply(a: i32, b: i32): i32;

struct A {
    a: i32;
}

struct B {
    @extends basea: A;
    b: i32;
}

@class
struct C {
    @extends baseb: B;
    c: i32;
}

@ctor("C")
function createC(): C;

interface IfaceA {
    func1(): void;
}

interface IfaceB: IfaceA {
    func2(): void;
}

@class
interface IfaceC: IfaceB {
    func3(): void;
}

@ctor("IfaceC")
function createIfaceC(): IfaceC;
