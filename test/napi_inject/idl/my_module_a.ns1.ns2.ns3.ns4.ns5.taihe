@!lib("my_module_a")

@!namespace("my_module_a", "ns1.ns2.ns3.ns4.ns5")
@!ts_inject_into_module("export const PI = 3.14159;")
function Funtest(s: MyStruct): i32;
struct MyStruct {
    a: i32;
    b: i32;
@!ts_inject_into_interface("add(a: number, b: number): number;")
}
function foo(): void;

@class
struct MyClass {
    a: bool;
    b: f32;
@!ts_inject_into_class("""mul(a: number, b: number): number {
    return a * b;
}
""")
}

@ctor("MyClass")
function create_myclass(a: bool, b: f32): MyClass;

@static("MyClass")
function add(a: i32, b: i32): i32;
