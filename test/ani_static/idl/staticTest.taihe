[class]
interface IBase {
    get(): String;
    set(a: String): void;
}

[static_method = "IBase"]
function sumSync(a: i32, b: i32): i32;

[static_method = "IBase", gen_async="add", gen_promise="add"]
function addSync(a: i32, b: i32): i32;

[ctor = "IBase"]
function getIBase(name: String): IBase;

[ctor = "IBase"]
function getIBase_test(name: String, test: String): IBase;

interface ITest {
    get(): String;
    set(a: String): void;
}

[static_method = "ITest", sts_name = "static_test"]
function static_func(a: i32, b: i32): i32;

[ctor = "ITest"]
function ctor_func(): ITest;
