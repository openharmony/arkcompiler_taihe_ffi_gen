struct RGB {
    r: u8;
    g: u8;
    b: u8;
}

struct RGBWithName {
    rgb: RGB;
    name: String;
}

enum Color {
    RED   = 0xff << 0o20;
    GREEN = 0xff << 0o10;
    BLUE  = 0xff << 0o00;
}

enum ColorOrRGBOrName {
    color: Color = 0x1;
    rgb: RGB = 0x2;
    name: String = 0x0;
}

[cname = "ohos_get_rgb", index = 0, has_return_val = TRUE, deprecated]
function get_rgb(color: Color): RGB;

[cname = "ohos_invert_rgb", index = 1, has_return_val = FALSE]
function invert_rgb(color: RGB): void;

