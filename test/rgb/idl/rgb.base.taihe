struct RGB {
    r: u8;
    g: u8;
    b: u8;
}

type NameType = String;

@[tuple]
struct RGBWithName {
    rgb: RGB;
    name: NameType;
}

enum Color {
    RED   = 0xff << 0o20;
    GREEN = 0xff << 0o10;
    BLUE  = 0xff << 0o00;
}

@[cname = "ohos_get_rgb", index = 0, deprecated]
function get_rgb(color: Color): RGB;

@[cname = "ohos_invert_rgb", index = 1]
function invert_rgb(color: RGB): ();

@[file_info = "\u6d4b\u8bd5"] // file attribute write at the end
