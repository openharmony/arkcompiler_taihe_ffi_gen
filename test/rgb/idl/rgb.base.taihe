struct RGB {
    r: u8;
    g: u8;
    b: u8;
}

type NameType = String;

struct RGBWithName {
    rgb: RGB;
    name: NameType;
}

enum Color {
    RED   = 0xff << 0o20;
    GREEN = 0xff << 0o10;
    BLUE  = 0xff << 0o00;
}

function get_rgb(color: Color): RGB;
function invert_rgb(color: RGB): ();
