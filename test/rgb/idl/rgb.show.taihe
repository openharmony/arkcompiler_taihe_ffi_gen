from rgb.base use RGB, Color, ColorOrRGBOrName;

interface IBase {
    function getId(): String;
}

interface IShape: IBase {
    function calculateArea(): f32;
}

interface IColorable: IBase {
    function getColor(): ColorOrRGBOrName;
    function setColor(c: ColorOrRGBOrName): void;
}

function copyColor(dst: IColorable, src: IColorable): void;

interface IShowable: IColorable, IShape {
    function show(): void;
}

function makeRectangle(id: String, h: f32, w: f32): IShape;
function makeColoredRectangle(id: String, c: ColorOrRGBOrName, h: f32, w: f32): IShowable;
