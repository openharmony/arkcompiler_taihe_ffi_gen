enum ImageFormat: i32 {
    YCBCR_422_SP = 1000,
    JPEG = 2000
}

enum DecodingDynamicRange: i32 {
    AUTO = 0,
    SDR = 1,
    HDR = 2
}

enum PackingDynamicRange: i32 {
    AUTO = 0,
    SDR = 1
}

enum AntiAliasingLevel: i32 {
    NONE = 0,
    LOW = 1,
    MEDIUM = 2,
    HIGH = 3
}

enum ScaleMode: i32 {
    FIT_TARGET_SIZE = 0,
    CENTER_CROP = 1
}

enum ComponentType: i32 {
    YUV_Y = 1,
    YUV_U = 2,
    YUV_V = 3,
    JPEG = 4
}

enum HdrMetadataKey: i32 {
    HDR_METADATA_TYPE = 0,
    HDR_STATIC_METADATA = 1,
    HDR_DYNAMIC_METADATA = 2,
    HDR_GAINMAP_METADATA = 3
}

enum HdrMetadataType: i32 {
    NONE = 0,
    BASE = 1,
    GAINMAP = 2,
    ALTERNATE = 3
}

struct Region {
    size: Size;
    x: i32;
    y: i32;
}

struct PositionArea {
    pixels: @arraybuffer Array<u8>;
    offset: i32;
    stride: i32;
    region: Region;
}

struct PackingOption {
    format: String;
    quality: i32;
    bufferSize: Optional<i32>;
    desiredDynamicRange: Optional<PackingDynamicRange>;
    needsPackProperties: Optional<bool>;
}

struct GetImagePropertyOptions {
    index: Optional<i32>;
    defaultValue: Optional<String>;
}

struct ImagePropertyOptions {
    index: Optional<i32>;
    defaultValue: Optional<String>;
}

struct Component {
    @readonly componentType: ComponentType;
    @readonly rowStride: i32;
    @readonly pixelStride: i32;
    @readonly byteBuffer: @arraybuffer Array<u8>;
}

struct InitializationOptions {
    size: Size;
    srcPixelFormat: Optional<PixelMapFormat>;
    pixelFormat: Optional<PixelMapFormat>;
    editable: Optional<bool>;
    alphaType: Optional<AlphaType>;
    scaleMode: Optional<ScaleMode>;
}

struct SourceOptions {
    sourceDensity: i32;
    sourcePixelFormat: Optional<PixelMapFormat>;
    sourceSize: Optional<Size>;
}

struct HdrStaticMetadata {
    displayPrimariesX: Array<i32>;
    displayPrimariesY: Array<i32>;
    whitePointX: i32;
    whitePointY: i32;
    maxLuminance: i32;
    minLuminance: i32;
    maxContentLightLevel: i32;
    maxFrameAverageLightLevel: i32;
}

struct GainmapChannel {
    gainmapMax: i32;
    gainmapMin: i32;
    gamma: i32;
    baseOffset: i32;
    alternateOffset: i32;
}

struct HdrGainmapMetadata {
    writerVersion: i32;
    miniVersion: i32;
    gainmapChannelCount: i32;
    useBaseColorFlag: bool;
    baseHeadroom: i32;
    alternateHeadroom: i32;
    channels: Array<GainmapChannel>;
}

// type HdrMetadataValue = HdrMetadataType | HdrStaticMetadata | @arraybuffer Array<u8> | HdrGainmapMetadata;
union HdrMetadataValue {
    metadataType: HdrMetadataType;
    staticMetadata: HdrStaticMetadata;
    gainmapMetadata: HdrGainmapMetadata;
    buffer: @arraybuffer Array<u8>;
}

// function createPixelMap(colors: @arraybuffer Array<u8>, options: InitializationOptions, callback: AsyncCallback<PixelMap>): void;
// function createPixelMap(colors: @arraybuffer Array<u8>, options: InitializationOptions): Promise<PixelMap>;
// function createPixelMapSync(colors: @arraybuffer Array<u8>, options: InitializationOptions): PixelMap;
// function createPixelMapSync(options: InitializationOptions): PixelMap;
@gen_async("createPixelMap")
@gen_promise("createPixelMap")
@overload("createPixelMapSync")
