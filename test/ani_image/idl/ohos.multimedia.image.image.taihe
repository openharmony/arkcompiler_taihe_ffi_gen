union NullablePixelMap {
    pixelMap: PixelMap;
    @null null;
}

union NullableAuxiliaryPicture {
    auxiliaryPicture: AuxiliaryPicture;
    @null null;
}

interface Picture {
    getMainPixelmap(): PixelMap;

    // getHdrComposedPixelmap(): Promise<PixelMap>;
    @gen_promise("getHdrComposedPixelmap")
    getHdrComposedPixelmapSync(): PixelMap;

    getGainmapPixelmap(): NullablePixelMap;
    setAuxiliaryPicture(type: AuxiliaryPictureType, auxiliaryPicture: AuxiliaryPicture): void;
    getAuxiliaryPicture(type: AuxiliaryPictureType): NullableAuxiliaryPicture;

    // setMetadata(metadataType: MetadataType, metadata: Metadata): Promise<void>;
    // getMetadata(metadataType: MetadataType): Promise<Metadata>;
    @gen_promise("setMetadata")
    setMetadataSync(metadataType: MetadataType, metadata: Metadata): void;
    @gen_promise("getMetadata")
    getMetadataSync(metadataType: MetadataType): Metadata;

    marshalling(sequence: rpc.MessageSequence): void;
    release(): void;
}

function createPicture(mainPixelmap: PixelMap): Picture;
function createPictureFromParcel(sequence: rpc.MessageSequence): Picture;
function createAuxiliaryPicture(buffer: @arraybuffer Array<u8>, size: Size, type: AuxiliaryPictureType): AuxiliaryPicture;

interface AuxiliaryPicture {
    // writePixelsFromBuffer(data: @arraybuffer Array<u8>): Promise<void>;
    @gen_promise("writePixelsFromBuffer")
    writePixelsFromBufferSync(data: @arraybuffer Array<u8>): void;

    // readPixelsToBuffer(): Promise<@arraybuffer Array<u8>>;
    @gen_promise("readPixelsToBuffer")
    readPixelsToBufferSync(): @arraybuffer Array<u8>;

    getType(): AuxiliaryPictureType;

    // setMetadata(metadataType: MetadataType, metadata: Metadata): Promise<void>;
    // getMetadata(metadataType: MetadataType): Promise<Metadata>;
    @gen_promise("setMetadata")
    setMetadataSync(metadataType: MetadataType, metadata: Metadata): void;
    @gen_promise("getMetadata")
    getMetadataSync(metadataType: MetadataType): Metadata;

    getAuxiliaryPictureInfo(): AuxiliaryPictureInfo;
    setAuxiliaryPictureInfo(info: AuxiliaryPictureInfo): void;
    release(): void;
}

enum AuxiliaryPictureType: i32 {
    GAINMAP = 1,
    DEPTH_MAP = 2,
    UNREFOCUS_MAP = 3,
    LINEAR_MAP = 4,
    FRAGMENT_MAP = 5
}

enum MetadataType: i32 {
    EXIF_METADATA = 1,
    FRAGMENT_METADATA = 2
}

interface Metadata {
    // getProperties(key: Array<String>): Promise<@record Map<String, NullableString>>;
    // setProperties(records: @record Map<String, NullableString>): Promise<void>;
    @gen_promise("getProperties")
    getPropertiesSync(key: Array<String>): @record Map<String, NullableString>;
    @gen_promise("setProperties")
    setPropertiesSync(records: @record Map<String, NullableString>): void;

    // getAllProperties(): Promise<@record Map<String, NullableString>>;
    @gen_promise("getAllProperties")
    getAllPropertiesSync(): @record Map<String, NullableString>;

    // clone(): Promise<Metadata>;
    @gen_promise("clone")
    cloneSync(): Metadata;
}

enum FragmentMapPropertyKey: String {
    X_IN_ORIGINAL = "XInOriginal",
    Y_IN_ORIGINAL = "YInOriginal",
    WIDTH = "FragmentImageWidth",
    HEIGHT = "FragmentImageHeight"
}

struct DecodingOptionsForPicture {
    desiredAuxiliaryPictures: Array<AuxiliaryPictureType>;
}

struct AuxiliaryPictureInfo {
    auxiliaryPictureType: AuxiliaryPictureType;
    size: Size;
    rowStride: i32;
    pixelFormat: PixelMapFormat;
    colorSpace: colorSpaceManager.ColorSpaceManager;
}

union NullableString {
    str: String;
    @null null;
}


interface ImagePacker {
    // packing(source: ImageSource, option: PackingOption, callback: AsyncCallback<@arraybuffer Array<u8>>): void;
    // packing(source: ImageSource, option: PackingOption): Promise<@arraybuffer Array<u8>>;
    @gen_async("packing")
    @gen_promise("packing")
    packingSyncImageSource(source: ImageSource, option: PackingOption): @arraybuffer Array<u8>;

    // packToData(source: ImageSource, options: PackingOption): Promise<@arraybuffer Array<u8>>;
    @gen_promise("packToData")
    packToDataSyncImageSource(source: ImageSource, options: PackingOption): @arraybuffer Array<u8>;

    // packing(source: PixelMap, option: PackingOption, callback: AsyncCallback<@arraybuffer Array<u8>>): void;
    // packing(source: PixelMap, option: PackingOption): Promise<@arraybuffer Array<u8>>;
    @gen_async("packing")
    @gen_promise("packing")
    packingSyncPixelMap(source: PixelMap, option: PackingOption): @arraybuffer Array<u8>;

    // packToData(source: PixelMap, options: PackingOption): Promise<@arraybuffer Array<u8>>;
    @gen_promise("packToData")
    packToDataSyncPixelMap(source: PixelMap, options: PackingOption): @arraybuffer Array<u8>;

    // packToFile(source: ImageSource, fd: i32, options: PackingOption, callback: AsyncCallback<void>): void;
    // packToFile(source: ImageSource, fd: i32, options: PackingOption): Promise<void>;
    // packToFile(source: PixelMap, fd: i32, options: PackingOption, callback: AsyncCallback<void>): void;
    // packToFile(source: PixelMap, fd: i32, options: PackingOption): Promise<void>;
    @gen_async("packToFile")
    @gen_promise("packToFile")
    packToFileSyncImageSource(source: ImageSource, fd: i32, options: PackingOption): void;
    @gen_async("packToFile")
    @gen_promise("packToFile")
    packToFileSyncPixelMap(source: PixelMap, fd: i32, options: PackingOption): void;

    // release(callback: AsyncCallback<void>): void;
    // release(): Promise<void>;
    @gen_async("release")
    @gen_promise("release")
    releaseSync(): void;

    // packing(picture: Picture, options: PackingOption): Promise<@arraybuffer Array<u8>>;
    @gen_promise("packing")
    packingSyncPicture(picture: Picture, options: PackingOption): @arraybuffer Array<u8>;

    // packToFile(picture: Picture, fd: i32, options: PackingOption): Promise<void>;
    @gen_promise("packToFile")
    packToFileSyncPicture(picture: Picture, fd: i32, options: PackingOption): void;

    // readonly supportedFormats: Array<String>;
    @get getSupportedFormats(): Array<String>;
}

interface Image {
    // clipRect: Region;
    // readonly size: Size;
    // readonly format: i32;
    // readonly timestamp: i32;
    @get getClipRect(): Region;
    @set setClipRect(value: Region): void;
    @get getSize(): Size;
    @get getFormat(): i32;
    @get getTimestamp(): i32;

    // getComponent(componentType: ComponentType, callback: AsyncCallback<Component>): void;
    // getComponent(componentType: ComponentType): Promise<Component>;
    @gen_async("getComponent")
    @gen_promise("getComponent")
    getComponentSync(componentType: ComponentType): Component;

    // release(callback: AsyncCallback<void>): void;
    // release(): Promise<void>;
    @gen_async("release")
    @gen_promise("release")
    releaseSync(): void;
}

interface ImageReceiver {
    // readonly size: Size;
