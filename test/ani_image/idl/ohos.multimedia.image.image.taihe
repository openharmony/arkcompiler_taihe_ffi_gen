// import { AsyncCallback } from "./@ohos.base";
// import type colorSpaceManager from "./@ohos.graphics.colorSpaceManager";
// import type resourceManager from "./@ohos.resourceManager";
// import type rpc from "./@ohos.rpc";
use ohos.graphics.colorSpaceManager.colorSpaceManager as colorSpaceManager;

@!namespace("@ohos.multimedia.image", "image")

interface ImageSource {
    // getImageInfo(index: i32, callback: AsyncCallback<ImageInfo>): void;
    // getImageInfo(callback: AsyncCallback<ImageInfo>): void;
    // getImageInfo(index: Optional<i32>): Promise<ImageInfo>;
    // getImageInfoSync(index: Optional<i32>): ImageInfo;
    @gen_promise("getImageInfo")
    getImageInfoSync(index: Optional<i32>): ImageInfo;
    @gen_async("getImageInfo")
    getImageInfoSyncWithoutIndex(): ImageInfo;
    @gen_async("getImageInfo")
    getImageInfoSyncWithIndex(index: i32): ImageInfo;

    // createPixelMap(options: Optional<DecodingOptions>): Promise<PixelMap>;
    // createPixelMap(callback: AsyncCallback<PixelMap>): void;
    // createPixelMap(options: DecodingOptions, callback: AsyncCallback<PixelMap>): void;
    // createPixelMapSync(options: Optional<DecodingOptions>): PixelMap;
    @gen_promise("createPixelMap")
    createPixelMapSync(options: Optional<DecodingOptions>): PixelMap;
    @gen_async("createPixelMap")
    createPixelMapSyncWithoutOptions(): PixelMap;
    @gen_async("createPixelMap")
    createPixelMapSyncWithOptions(options: DecodingOptions): PixelMap;

    // createPixelMapList(options: Optional<DecodingOptions>): Promise<Array<PixelMap>>;
    // createPixelMapList(callback: AsyncCallback<Array<PixelMap>>): void;
    // createPixelMapList(options: DecodingOptions, callback: AsyncCallback<Array<PixelMap>>): void;
    @gen_promise("createPixelMapList")
    createPixelMapListSync(options: Optional<DecodingOptions>): Array<PixelMap>;
    @gen_async("createPixelMapList")
    createPixelMapListSyncWithoutOptions(): Array<PixelMap>;
    @gen_async("createPixelMapList")
    createPixelMapListSyncWithOptions(options: DecodingOptions): Array<PixelMap>;

    // getDelayTimeList(): Promise<Array<i32>>;
    // getDelayTimeList(callback: AsyncCallback<Array<i32>>): void;
    @gen_promise("getDelayTimeList")
    @gen_async("getDelayTimeList")
    getDelayTimeListSync(): Array<i32>;

    // getDisposalTypeList(): Promise<Array<i32>>;
    @gen_promise("getDisposalTypeList")
    getDisposalTypeListSync(): Array<i32>;

    // getFrameCount(): Promise<i32>;
    // getFrameCount(callback: AsyncCallback<i32>): void;
    @gen_promise("getFrameCount")
    @gen_async("getFrameCount")
    getFrameCountSync(): i32;

    // getImageProperty(key: PropertyKey, options: Optional<ImagePropertyOptions>): Promise<String>;
    // getImageProperty(key: String, options: Optional<GetImagePropertyOptions>): Promise<String>;
    // getImageProperty(key: String, callback: AsyncCallback<String>): void;
    // getImageProperty(key: String, options: GetImagePropertyOptions, callback: AsyncCallback<String>): void;
    @gen_promise("getImageProperty")
    getImagePropertySyncPropertyKey(key: PropertyKey, options: Optional<ImagePropertyOptions>): String;
    @gen_promise("getImageProperty")
    getImagePropertySync(key: String, options: Optional<GetImagePropertyOptions>): String;
    @gen_async("getImageProperty")
    getImagePropertySyncWithoutOptions(key: String): String;
    @gen_async("getImageProperty")
    getImagePropertySyncWithOptions(key: String, options: GetImagePropertyOptions): String;

    // getImageProperties(key: Array<PropertyKey>): Promise<@record Map<PropertyKey, NullableString>>;
    @gen_promise("getImageProperties")
    getImagePropertiesSync(key: Array<PropertyKey>): @record Map<PropertyKey, NullableString>;

    // modifyImageProperty(key: PropertyKey, value: String): Promise<void>;
    // modifyImageProperty(key: String, value: String): Promise<void>;
    // modifyImageProperty(key: String, value: String, callback: AsyncCallback<void>): void;
    @gen_promise("modifyImageProperty")
    modifyImagePropertySyncPropertyKey(key: PropertyKey, value: String): void;
    @gen_promise("modifyImageProperty")
    @gen_async("modifyImageProperty")
    modifyImagePropertySync(key: String, value: String): void;

    // modifyImageProperties(records: @record Map<PropertyKey, NullableString>): Promise<void>;
    @gen_promise("modifyImageProperties")
    modifyImagePropertiesSync(records: @record Map<PropertyKey, NullableString>): void;

    // updateData(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32): Promise<void>;
    // updateData(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32, callback: AsyncCallback<void>): void;
    @gen_promise("updateData")
    @gen_async("updateData")
    updateDataSync(buf: @arraybuffer Array<u8>, isFinished: bool, offset: i32, length: i32): void;

    // release(callback: AsyncCallback<void>): void;
    // release(): Promise<void>;
    @gen_async("release")
    @gen_promise("release")
    releaseSync(): void;

    // createPicture(options: Optional<DecodingOptionsForPicture>): Promise<Picture>;
    @gen_promise("createPicture")
    createPictureSync(options: Optional<DecodingOptionsForPicture>): Picture;

    // readonly supportedFormats: Array<String>;
    @get getSupportedFormats(): Array<String>;
}

struct DecodingOptions {
    index: Optional<i32>;
    sampleSize: Optional<i32>;
    rotate: Optional<i32>;
    editable: Optional<bool>;
    desiredSize: Optional<Size>;
    desiredRegion: Optional<Region>;
    desiredPixelFormat: Optional<PixelMapFormat>;
    fitDensity: Optional<i32>;
    desiredColorSpace: Optional<colorSpaceManager.ColorSpaceManager>;
    desiredDynamicRange: Optional<DecodingDynamicRange>;
}

struct ImageInfo {
    size: Size;
    density: i32;
    stride: i32;
    pixelFormat: PixelMapFormat;
    alphaType: AlphaType;
    mimeType: String;
    isHdr: bool;
}

enum AlphaType: i32 {
    UNKNOWN = 0,
    OPAQUE = 1,
    PREMUL = 2,
    UNPREMUL = 3
}

enum PixelMapFormat: i32 {
    UNKNOWN = 0,
    RGB_565 = 2,
    RGBA_8888 = 3,
    BGRA_8888 = 4,
    RGB_888 = 5,
    ALPHA_8 = 6,
    RGBA_F16 = 7,
    NV21 = 8,
    NV12 = 9,
    RGBA_1010102 = 10,
    YCBCR_P010 = 11,
    YCRCB_P010 = 12
}

interface PixelMap {
    // readonly isEditable: bool;
    @get getIsEditable(): bool;

    // readPixelsToBuffer(dst: @arraybuffer Array<u8>): Promise<void>;
    // readPixelsToBuffer(dst: @arraybuffer Array<u8>, callback: AsyncCallback<void>): void;
    // readPixelsToBufferSync(dst: @arraybuffer Array<u8>): void;
    @gen_async("readPixelsToBuffer")
    @gen_promise("readPixelsToBuffer")
    readPixelsToBufferSync(dst: @arraybuffer Array<u8>): void;

    // readPixels(area: PositionArea): Promise<void>;
    // readPixels(area: PositionArea, callback: AsyncCallback<void>): void;
    // readPixelsSync(area: PositionArea): void;
    @gen_async("readPixels")
    @gen_promise("readPixels")
    readPixelsSync(area: PositionArea): void;

    // writePixels(area: PositionArea): Promise<void>;
    // writePixels(area: PositionArea, callback: AsyncCallback<void>): void;
    // writePixelsSync(area: PositionArea): void;
    @gen_async("writePixels")
    @gen_promise("writePixels")
    writePixelsSync(area: PositionArea): void;

    // writeBufferToPixels(src: @arraybuffer Array<u8>): Promise<void>;
    // writeBufferToPixels(src: @arraybuffer Array<u8>, callback: AsyncCallback<void>): void;
    // writeBufferToPixelsSync(src: @arraybuffer Array<u8>): void;
    @gen_async("writeBufferToPixels")
    @gen_promise("writeBufferToPixels")
    writeBufferToPixelsSync(src: @arraybuffer Array<u8>): void;

    // toSdr(): Promise<void>;
    @gen_promise("toSdr")
    toSdrSync(): void;

    // getImageInfo(): Promise<ImageInfo>;
    // getImageInfo(callback: AsyncCallback<ImageInfo>): void;
    // getImageInfoSync(): ImageInfo;
    @gen_async("getImageInfo")
    @gen_promise("getImageInfo")
    getImageInfoSync(): ImageInfo;

    getBytesNumberPerRow(): i32;
    getPixelBytesNumber(): i32;
    getDensity(): i32;

    // opacity(rate: i32, callback: AsyncCallback<void>): void;
    // opacity(rate: i32): Promise<void>;
    // opacitySync(rate: i32): void;
    @gen_async("opacity")
    @gen_promise("opacity")
    opacitySync(rate: i32): void;

    // createAlphaPixelmap(): Promise<PixelMap>;
    // createAlphaPixelmap(callback: AsyncCallback<PixelMap>): void;
    // createAlphaPixelmapSync(): PixelMap;
    @gen_async("createAlphaPixelmap")
    @gen_promise("createAlphaPixelmap")
    createAlphaPixelmapSync(): PixelMap;

    // scale(x: i32, y: i32, callback: AsyncCallback<void>): void;
    // scale(x: i32, y: i32): Promise<void>;
    // scaleSync(x: i32, y: i32): void;
    // scale(x: i32, y: i32, level: AntiAliasingLevel): Promise<void>;
    // scaleSync(x: i32, y: i32, level: AntiAliasingLevel): void;
    @gen_async("scale")
    @gen_promise("scale")
    @overload("scaleSync")
    scaleSyncWithoutLevel(x: i32, y: i32): void;
    @gen_async("scale")
    @gen_promise("scale")
    @overload("scaleSync")
    scaleSyncWithLevel(x: i32, y: i32, level: AntiAliasingLevel): void;

    // translate(x: i32, y: i32, callback: AsyncCallback<void>): void;
    // translate(x: i32, y: i32): Promise<void>;
    // translateSync(x: i32, y: i32): void;
    @gen_async("translate")
    @gen_promise("translate")
    translateSync(x: i32, y: i32): void;

    // rotate(angle: i32, callback: AsyncCallback<void>): void;
    // rotate(angle: i32): Promise<void>;
    // rotateSync(angle: i32): void;
    @gen_async("rotate")
    @gen_promise("rotate")
    rotateSync(angle: i32): void;

    // flip(horizontal: bool, vertical: bool, callback: AsyncCallback<void>): void;
    // flip(horizontal: bool, vertical: bool): Promise<void>;
    // flipSync(horizontal: bool, vertical: bool): void;
    @gen_async("flip")
    @gen_promise("flip")
    flipSync(horizontal: bool, vertical: bool): void;

    // crop(region: Region, callback: AsyncCallback<void>): void;
    // crop(region: Region): Promise<void>;
    // cropSync(region: Region): void;
    @gen_async("crop")
    @gen_promise("crop")
    cropSync(region: Region): void;

    getColorSpace(): colorSpaceManager.ColorSpaceManager;

    marshalling(sequence: rpc.MessageSequence): void;
    // unmarshalling(sequence: rpc.MessageSequence): Promise<PixelMap>;
    @gen_promise("unmarshalling")
    unmarshallingSync(sequence: rpc.MessageSequence): PixelMap;

    setColorSpace(colorSpace: colorSpaceManager.ColorSpaceManager): void;

    // readonly isStrideAlignment: bool;
    @get getIsStrideAlignment(): bool;

    // applyColorSpace(targetColorSpace: colorSpaceManager.ColorSpaceManager, callback: AsyncCallback<void>): void;
    // applyColorSpace(targetColorSpace: colorSpaceManager.ColorSpaceManager): Promise<void>;
    @gen_async("applyColorSpace")
    @gen_promise("applyColorSpace")
    applyColorSpaceSync(targetColorSpace: colorSpaceManager.ColorSpaceManager): void;

    // convertPixelFormat(targetPixelFormat: PixelMapFormat): Promise<void>;
    @gen_promise("convertPixelFormat")
    convertPixelFormatSync(targetPixelFormat: PixelMapFormat): void;

    // release(callback: AsyncCallback<void>): void;
    // release(): Promise<void>;
    @gen_async("release")
    @gen_promise("release")
    releaseSync(): void;

    setTransferDetached(detached: bool): void;
    getMetadata(key: HdrMetadataKey): HdrMetadataValue;
    setMemoryNameSync(name: String): void;

    // setMetadata(key: HdrMetadataKey, value: HdrMetadataValue): Promise<void>;
    @gen_promise("setMetadata")
    setMetadataSync(key: HdrMetadataKey, value: HdrMetadataValue): void;
}

struct Size {
    height: i32;
    width: i32;
}

