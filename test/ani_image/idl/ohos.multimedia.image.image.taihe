use ohos.graphics.colorSpaceManager.colorSpaceManager as colorSpaceManager;

@!namespace("@ohos.multimedia.image", "image")

struct Size {
    height: i32;
    width: i32;
}

enum PixelMapFormat: i32 {
    UNKNOWN = 0,
    RGB_565 = 2,
    RGBA_8888 = 3,
    BGRA_8888 = 4,
    RGB_888 = 5,
    ALPHA_8 = 6,
    RGBA_F16 = 7,
    NV21 = 8,
    NV12 = 9,
    RGBA_1010102 = 10,
    YCBCR_P010 = 11,
    YCRCB_P010 = 12
}

enum DecodingDynamicRange: i32 {
    AUTO = 0,
    SDR = 1,
    HDR = 2
}

enum AntiAliasingLevel: i32 {
    NONE = 0,
    LOW = 1,
    MEDIUM = 2,
    HIGH = 3
}

struct DecodingOptions {
    @optional index: Optional<i32>;
    @optional sampleSize: Optional<i32>;
    @optional rotate: Optional<i32>;
    @optional editable: Optional<bool>;
    @optional desiredSize: Optional<Size>;
    @optional desiredRegion: Optional<Region>;
    @optional desiredPixelFormat: Optional<PixelMapFormat>;
    @optional fitDensity: Optional<i32>;
    @optional desiredColorSpace: Optional<colorSpaceManager.ColorSpaceManager>;
    @optional desiredDynamicRange: Optional<DecodingDynamicRange>;
}

enum AlphaType: i32 {
    UNKNOWN = 0,
    OPAQUE = 1,
    PREMUL = 2,
    UNPREMUL = 3
}

union NullableString {
    str: String;
    null: @null unit;
}

struct Region {
    size: Size;
    x: i32;
    y: i32;
}

interface PixelMap {
    createAlphaPixelmapSync(): PixelMap;
    @rename("createAlphaPixelmap")
    @promise
    createAlphaPixelmapReturnsPromise(): PixelMap;
    @rename("createAlphaPixelmap")
    @async
    createAlphaPixelmapWithCallback(): PixelMap;

    getImageInfoSync(): ImageInfo;
    @rename("getImageInfo")
    @promise
    getImageInfoReturnsPromise(): ImageInfo;
    @rename("getImageInfo")
    @async
    getImageInfoWithCallback(): ImageInfo;

    getBytesNumberPerRow(): i32;
    getPixelBytesNumber(): i32;

    readPixelsToBufferSync(buff: @arraybuffer Array<u8>);
    @rename("readPixelsToBuffer")
    @promise
    readPixelsToBufferReturnsPromise(buff: @arraybuffer Array<u8>);
    @rename("readPixelsToBuffer")
    @async
    readPixelsToBufferWithCallback(buff: @arraybuffer Array<u8>);

    @rename("scaleSync")
    scaleSyncWithoutLevel(x: f64, y: f64): void;
    @rename("scaleSync")
    scaleSyncWithLevel(x: f64, y: f64, level: AntiAliasingLevel): void;

    cropSync(region: Region): void;
    @rename("crop")
    @promise
    cropReturnsPromise(region: Region): void;
    @rename("crop")
    @async
    cropWithCallback(region: Region): void;

    flipSync(horizontal: bool, vertical: bool): void;

    @rename("release")
    @promise
    releaseReturnsPromise(): void;
    @rename("release")
    @async
    releaseWithCallback(): void;

    getInner(): i64;
}

struct ImageInfo {
    size: Size;
    density: i32;
    stride: i32;
    pixelFormat: PixelMapFormat;
    alphaType: AlphaType;
    mimeType: String;
    isHdr: bool;
}

interface ImageSource {
    getImageInfoSync(@optional index: Optional<i32>): ImageInfo;
    @rename("getImageInfo")
    @promise
    getImageInfoReturnsPromise(@optional index: Optional<i32>): ImageInfo;
    @rename("getImageInfo")
    @async
    getImageInfoWithCallbackWithIndex(index: i32): ImageInfo;
    @rename("getImageInfo")
    @async
    getImageInfoWithCallbackWithoutIndex(): ImageInfo;

    createPixelMapSync(@optional options: Optional<DecodingOptions>): PixelMap;
    @rename("createPixelMap")
    @promise
    createPixelMapReturnsPromise(@optional options: Optional<DecodingOptions>): PixelMap;
    @rename("createPixelMap")
    @async
    createPixelMapWithCallbackWithOptions(options: DecodingOptions): PixelMap;
    @rename("createPixelMap")
    @async
    createPixelMapWithCallbackWithoutOptions(): PixelMap;

    modifyImageProperty(key: String, value: String): void;

    @promise
    modifyImageProperties(records: @record Map<String, NullableString>): void;

    @promise
    getImageProperties(key: Array<String>): @record Map<String, NullableString>;

    @rename("release")
    @promise
    releaseReturnsPromise(): void;
    @rename("release")
    @async
    releaseWithCallback(): void;
}
