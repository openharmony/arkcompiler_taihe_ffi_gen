// Basic tuple with primitive types
@tuple
struct IntPair {
    first: i32;
    second: i32;
}

// Tuple with mixed primitive types
@tuple
struct MixedTuple {
    a: i8;
    b: i16;
    c: i32;
    d: i64;
    e: f32;
    f: f64;
    g: bool;
}

// Tuple with string
@tuple
struct StringPair {
    key: String;
    value: String;
}

// Tuple with mixed ref and primitive types
@tuple
struct MixedRefTuple {
    name: String;
    age: i32;
    score: f64;
    active: bool;
    metadata: @record Map<String, String>;
    callback: Optional<(data: String) => void>;
}

// Tuple as function return value (pass out)
function MakeIntPair(a: i32, b: i32): IntPair;

// Tuple as function parameter (pass in)
function SumIntPair(p: IntPair): i32;

// Tuple roundtrip
function SwapIntPair(p: IntPair): IntPair;

// Mixed tuple roundtrip
function ProcessMixed(m: MixedTuple): MixedTuple;

// String pair
function MakeStringPair(k: String, v: String): StringPair;
function ConcatStringPair(p: StringPair): String;

// Mixed ref tuple
function MakeMixedRef(name: String, age: i32, score: f64, active: bool, metadata: Map<String, String>): MixedRefTuple;
function DescribeMixedRef(m: MixedRefTuple): String;

// Array of tuples
function MakeIntPairArray(n: i32): Array<IntPair>;
function SumIntPairArray(pairs: Array<IntPair>): i32;

// Tuple containing an Array
@tuple
struct ArrayTuple {
    label: String;
    values: Array<i32>;
}

function MakeArrayTuple(label: String, n: i32): ArrayTuple;
function SumArrayTuple(t: ArrayTuple): String;

@tuple struct MyTuple4 {
    a: i32;
    b: i32;
    c: i32;
    d: i32;
}

@tuple struct MyTuple4x4 {
    a: MyTuple4;
    b: MyTuple4;
    c: MyTuple4;
    d: MyTuple4;
}

function TransposeMyTuple4x4(t: MyTuple4x4): MyTuple4x4;

@tuple struct MyTuple4Array {
    a: Array<i32>;
    b: Array<i32>;
    c: Array<i32>;
    d: Array<i32>;
}

function TransposeMyTuple4Array(t: MyTuple4Array): Array<MyTuple4>;
function TransposeArrayMyTuple4(t: Array<MyTuple4>): MyTuple4Array;

@tuple struct MyTuple16 {
    f0: i32;
    f1: i32;
    f2: i32;
    f3: i32;
    f4: i32;
    f5: i32;
    f6: i32;
    f7: i32;
    f8: i32;
    f9: i32;
    fa: i32;
    fb: i32;
    fc: i32;
    fd: i32;
    fe: i32;
    ff: i32;
}

function MakeMyTuple16(
    p0: i32,
    p1: i32,
    p2: i32,
    p3: i32,
    p4: i32,
    p5: i32,
    p6: i32,
    p7: i32,
    p8: i32,
    p9: i32,
    pa: i32,
    pb: i32,
    pc: i32,
    pd: i32,
    pe: i32,
    pf: i32,
): MyTuple16;

function SumMyTuple16(t: MyTuple16): i32;

// Empty tuple is not supported since taihe does not allow zero-field struct
// @tuple struct EmtyTuple {}

// @optional actually has no effect on tuple fields since TS does not support optional fields in tuples
// @tuple struct TupleWithOptionalField {
//     @optional a: Optional<String>;
// }

// Single-field tuple
@tuple struct SingleFieldTuple {
    value: i32;
}

function MakeSingleFieldTuple(v: i32): SingleFieldTuple;
function GetSingleFieldValue(t: SingleFieldTuple): i32;

// Nested tuples
@tuple struct InnerTuple {
    a: i32;
    b: String;
}

@tuple struct MiddleTuple {
    a: i32;
    b: InnerTuple;
}

@tuple struct OuterTuple {
    a: i32;
    b: MiddleTuple;
}

function MakeOuterTuple(a: i32, b: i32, c: i32, s: String): OuterTuple;
function DescribeOuterTuple(t: OuterTuple): String;

// Tuple with enum, struct, union, interface fields
enum Color: i32 {
    Red,
    Green,
    Blue,
}

struct Point {
    x: f64;
    y: f64;
}

union NameOrId {
    name: String;
    id: i32;
}

interface Printable {
    print(): String;
}

@tuple struct ComplexTuple {
    color: Color;
    point: Point;
    nameOrId: NameOrId;
    printable: Printable;
}

function DescribeComplexTuple(t: ComplexTuple): String;
