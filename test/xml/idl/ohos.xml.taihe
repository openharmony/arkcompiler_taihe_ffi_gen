// enum BufferType {
//     arr: ArrayBuffer;
//     data: DataView;
// }

struct BufferType {
    content: String;
}

interface XmlSerializer {
    setAttributes(name: String, value: String): void;
    addEmptyElement(name: String): void;
    setDeclaration(): void;
    startElement(name: String): void;
    endElement(): void;
    setNamespace(prefix: String, namespace_: String): void;
    setComment(text: String): void;
    setCDATA(text: String): void;
    setText(text: String): void;
    setDocType(text: String): void;
}

function makeXmlSerializer(buffer: BufferType, encoding: Box<String>): XmlSerializer;

enum EventType {
    START_DOCUMENT;
    END_DOCUMENT;
    START_TAG;
    END_TAG;
    TEXT;
    CDSECT;
    COMMENT;
    DOCDECL;
    INSTRUCTION;
    ENTITY_REFERENCE;
    WHITESPACE;
}

interface ParseInfo {
    getColumnNumber(): u64;
    getDepth(): u64;
    getLineNumber(): u64;
    getName(): String;
    getNamespace(): String;
    getPrefix(): String;
    getText(): String;
    isEmptyElementTag(): bool;
    isWhitespace(): bool;
    getAttributeCount(): u64;
}

struct ParseOptions {
    supportDoctype: Box<bool>;
    ignoreNameSpace: Box<bool>;
    tagValueCallbackFunction: Box<(name: String, value: String) => bool>;
    attributeValueCallbackFunction: Box<(name: String, value: String) => bool>;
    tokenValueCallbackFunction: Box<(eventType: EventType, value: ParseInfo) => bool>;
}

interface XmlPullParser {
    parse(option: ParseOptions): void;
    parseXml(option: ParseOptions): void;
}

function makeXmlPullParser(buffer: BufferType, encoding: Box<String>): XmlPullParser;
