struct Option {
    src: String;
    dest: f64;
    files: Array<String>;
}

enum Union {
    empty;
    iValue: i32;
    fValue: f32;
    sValue: String;
}

interface Foo {
    bar(): void;
}

function callBar(foo: Foo, time: i32): void;
function getFoo(): Foo;

function testUnion(u: Union): void;
function getUnion(v: i32): Union;
function getOption(): Option;

function testOptionalDouble(x: Optional<f64>): void;

function optionPrim(num: f64): void;
function optionArg1(str: String, op1: Option): void;
function optionArg2(str: String, op1: Option, op2: Option): void;
function optionArg3(str: String, op1: Option, op2: Option, op3: Option): void;

function getNumberArg0(): i32;
function getNumberArg4(x: i32, y: i32, z: i32, w: i32): i32;
