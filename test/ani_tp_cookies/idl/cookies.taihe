struct AntUserCookie {
    @readonly domain: String;
    @readonly expires: String;
    @readonly path: String;
    @readonly httpOnly: bool;
    @readonly cookieString: String;
}

interface AntUserCookiesProvider {
    getCookiesString(url: String): Optional<String>;
    hasCookies(url: String): bool;
    setCookies(cookies: Array<AntUserCookie>): bool;
    setCookiesAsync(cookies: Array<AntUserCookie>, callback: (res: bool) => void): void;
    removeCookies(url: String): bool;
    clearCookies(): bool;
    clearCookiesAsync(callback: (res: bool) => void): void;
    saveCookies(): bool;
    saveCookiesAsync(callback: (res: bool) => void): bool;
}
