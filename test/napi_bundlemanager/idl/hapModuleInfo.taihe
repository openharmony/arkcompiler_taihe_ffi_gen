interface HapModuleInfo {
    @get("name") GetName(): String;
    @get("icon") GetIcon(): String;
    @get("iconId") GetIconId(): i32;
    @get("label") GetLabel(): String;
    @get("labelId") GetLabelId(): i32;
    @get("description") GetDescription(): String;
    @get("descriptionId") GetDescriptionId(): i32;
    @get("mainElementName") GetMainElementName(): String;
    @get("deviceTypes") GetDeviceTypes(): Array<String>;
    @get("installationFree") GetInstallationFree(): bool;
    @get("hashValue") GetHashValue(): String;
    @get("fileContextMenuConfig") GetFileContextMenuConfig(): String;
    @get("nativeLibraryPath") GetNativeLibraryPath(): String;
    @get("codePath") GetCodePath(): String;
}
function GetHapModuleInfo(): HapModuleInfo;

interface Dependency {
    @get("moduleName") GetModuleName(): String;
    @get("bundleName") GetBundleName(): String;
    @get("versionCode") GetVersionCode(): i32;
}
function GetDependency(): Dependency;

interface PreloadItem {
    @get("moduleName") GetModuleName(): String;
}
function GetPreloadItem(): PreloadItem;

interface RouterItem {
    @get("name") GetName(): String;
    @get("pageSourceFile") GetPageSourceFile(): String;
    @get("buildFunction") GetBuildFunction(): String;
    @get("customData") GetCustomData(): String;
}
function GetRouterItem(): RouterItem;

interface DataItem {
    @get("key") GetKey(): String;
    @get("value") GetValue(): String;
}
function GetDataItem(): DataItem;