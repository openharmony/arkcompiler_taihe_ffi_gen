use ohos.bundle.bundleManager as bundleManager;
from applicationInfo use ApplicationInfo as ApplicationInfo;
from metadata use Metadata as Metadata;
from skill use Skill as Skill;

interface AbilityInfo {
    @get("bundleName") GetBundleName(): String;
    @get("moduleName") GetModuleName(): String;
    @get("name") GetName(): String;
    @get("label") GetLabel(): String;
    @get("labelId") GetLabelId(): i32;
    @get("description") GetDescription(): String;
    @get("descriptionId") GetDescriptionId(): i32;
    @get("icon") GetIcon(): String;
    @get("iconId") GetIconId(): i32;
    @get("process") GetProcess(): String;
    @get("exported") GetExported(): bool;
    @get("type") GetType(): bundleManager.AbilityType;
    @get("orientation") GetOrientation(): bundleManager.DisplayOrientation;
    @get("launchType") GetLaunchType(): bundleManager.LaunchType;
    @get("permissions") GetPermissions(): Array<String>;
    @get("readPermission") GetReadPermission(): String;
    @get("writePermission") GetWritePermission(): String;
    @get("uri") GetUri(): String;
    @get("deviceTypes") GetDeviceTypes(): Array<String>;
    @get("metadata") GetMetadata(): Array<Metadata>;    
    @get("enabled") GetEnabled(): bool;
    @get("supportWindowModes") GetSupportWindowModes(): Array<bundleManager.SupportWindowMode>;    
    @get("excludeFromDock") GetExcludeFromDock(): bool;
    @get("skills") GetSkills(): Array<Skill>;
    @get("appIndex") GetAppIndex(): i32;
    @get("orientationId") GetOrientationId(): i32;
}
function GetAbilityInfo(): AbilityInfo;