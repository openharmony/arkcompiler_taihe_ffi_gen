interface ApplicationInfo {
    @get("name") GetName(): String;
    @get("description") GetDescription(): String;
    @get("descriptionId") GetDescriptionId(): i32;
    @get("enabled") GetEnabled(): bool;
    @get("label") GetLabel(): String;
    @get("labelId") GetLabelId(): i32;
    @get("icon") GetIcon(): String;
    @get("iconId") GetIconId(): i32;
    @get("process") GetProcess(): String;
    @get("permissions") GetPermissions(): Array<String>;
    @get("codePath") GetCodePath(): String;
    @get("removable") GetRemovable(): bool;
    @get("accessTokenId") GetAccessTokenId(): i32;
    @get("uid") GetUid(): i32;
    @get("appDistributionType") GetAppDistributionType(): String;
    @get("appProvisionType") GetAppProvisionType(): String;
    @get("systemApp") GetSystemApp(): bool;
    @get("debug") GetDebug(): bool;
    @get("dataUnclearable") GetDataUnclearable(): bool;
    @get("nativeLibraryPath") GetNativeLibraryPath(): String;
    @get("appIndex") GetAppIndex(): i32;
    @get("installSource") GetInstallSource(): String;
    @get("releaseType") GetReleaseType(): String;
    @get("cloudFileSyncEnabled") GetCloudFileSyncEnabled(): bool;
}
function GetApplicationInfo(): ApplicationInfo;

interface ModuleMetadata {
    @get("moduleName") GetModuleName(): String;
}
function GetModuleMetadata(): ModuleMetadata;

interface MultiAppMode {
    @get("maxCount") GetMaxCount(): i32;
}
function GetMultiAppMode(): MultiAppMode;