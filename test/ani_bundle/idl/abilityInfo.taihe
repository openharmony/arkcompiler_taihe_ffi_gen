interface AbilityInfo {
    @get GetBundleName(): String;
    @get GetName(): String;
    @get GetLabel(): String;
    @get GetDescription(): String;
    @get GetIcon(): String;
    @get GetLabelId(): i32;
    @get GetDescriptionId(): i32;
    @get GetIconId(): i32;
    @get GetModuleName(): String;
    @get GetProcess(): String; 
    @get GetTargetAbility(): String;   
    @get GetBackgroundModes(): i32;   
    @get GetIsVisible(): bool;  
    @get GetFormEnabled(): bool; 
    @get GetPermissions(): Array<String>;
    @get GetDeviceTypes(): Array<String>;
    @get GetDeviceCapabilities(): Array<String>;
    @get GetReadPermission(): String;  
    @get GetWritePermission(): String;  
    @get GetUri(): String;  
    @get GetEnabled(): bool;
}
function GetAbilityInfo(): AbilityInfo;