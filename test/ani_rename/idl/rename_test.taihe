// Test @rename on function
@rename("add")
function OldAdd(a: i32, b: i32): i32;

// Test @rename on enum declaration and enum items
@rename("Color")
enum OldColor: i32 {
    @rename("red") RED = 0,
    @rename("green") GREEN = 1,
    @rename("blue") BLUE = 2,
}

function GetColorValue(c: OldColor): i32;

// Test @rename on const enum items
@const
enum OldMaxValue: i32 {
    @rename("INT_MAX") OLD_INT_MAX = 2147483647,
    @rename("ZERO") OLD_ZERO = 0,
}

// Test @rename on struct declaration and struct fields
@rename("Point")
struct OldPoint {
    @rename("xPos") x: i32;
    @rename("yPos") y: i32;
}

function CreatePoint(x: i32, y: i32): OldPoint;
function GetPointSum(p: OldPoint): i32;

// Test @rename on interface declaration
@rename("Calculator")
interface OldCalculator {
    @rename("compute")
    OldCompute(a: i32, b: i32): i32;
}

function CreateCalculator(): OldCalculator;

// Test @rename on union declaration
@rename("Data")
union OldData {
    intVal: i32;
    strVal: String;
}

function CreateIntData(v: i32): OldData;
function CreateStrData(v: String): OldData;
