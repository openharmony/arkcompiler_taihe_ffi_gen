// Test @rename on function
@rename("add")
function OldAdd(@rename("lhs") a: i32, @rename("rhs") b: i32): i32;

// Test @rename on enum declaration and enum items
@rename("Color")
enum OldColor: i32 {
    @rename("red") RED = 0,
    @rename("green") GREEN = 1,
    @rename("blue") BLUE = 2,
}

function GetColorValue(c: OldColor): i32;

// Test @rename on const enum items
@const
enum OldMaxValue: i32 {
    @rename("INT_MAX") OLD_INT_MAX = 2147483647,
    @rename("ZERO") OLD_ZERO = 0,
}

// Test @rename on struct declaration and struct fields
@rename("Point")
struct OldPoint {
    @rename("xPos") x: i32;
    @rename("yPos") y: i32;
}

function CreatePoint(x: i32, y: i32): OldPoint;
function GetPointSum(p: OldPoint): i32;

// Test @rename on interface declaration
@rename("Calculator")
interface OldCalculator {
    @rename("compute")
    OldCompute(a: i32, b: i32): i32;
}

function CreateCalculator(): OldCalculator;

// Test @rename on union declaration
@rename("Data")
union OldData {
    intVal: i32;
    strVal: String;
}

function CreateIntData(v: i32): OldData;
function CreateStrData(v: String): OldData;

@class
@rename("MyStruct")
struct OldMyStruct {
    a: i32;
    b: String;
}

@ctor("MyStruct")
function MyStructCtor(dummy: unit, a: i32, b: String): OldMyStruct;

@static("MyStruct")
@rename("staticFunc")
function MyStructStaticFunc(): String;

@class
@rename("MyInterface")
interface OldMyInterface {
    doSomething(s: String): String;
}

@ctor("MyInterface")
function MyInterfaceCtor(dummy: unit): OldMyInterface;

@static("MyInterface")
@rename("staticMethod")
function MyInterfaceStaticMethod(): String;

enum EnumWithNull: i32 {
    // `NULL` is a common macro defined in C/C++, so the following line will cause a syntax error in generated C/C++ code
    // NULL = 0,

    // Instead, you can name the enum item something else and use `@rename` to rename it to `NULL` in generated ArkTS code
    @rename("NULL") fieldNULL = 0,
}

interface InterfaceWithUseFrom {
    // `use` and `from` are Taihe keywords, so the following lines will cause syntax errors
    // use();
    // from();

    // Instead, we can use `#` before the identifiers to escape the keywords
    #use();
    #from();
}
