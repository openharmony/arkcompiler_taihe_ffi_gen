interface Foo {
    Bar(): void;
    @set("name") SetName(name: String): void;
    @get("name") GetName(): String;
}

function GetFooIface(): Foo;
function PrintFooName(foo: Foo): String;

interface BaseFun {
    Base(): String;
    Fun(): String;
}
function GetBaseFun(): BaseFun;

interface SubBaseFun: BaseFun {
    Sub(): String;
}
function GetSubBaseFun(): SubBaseFun;

interface BaseElem {
    @get GetBase(): String;
    @set SetBase(s: String): void;
}
function GetBaseElem(): BaseElem;

interface SubBaseElem: BaseElem {
    Sub(): String;
}
function GetSubBaseElem(): SubBaseElem;

interface IBase {
    GetId(): String;
    SetId(s: String): void;
}

function MakeIBase(id: String): IBase;
function CopyIBase(a: IBase, b: IBase): void;

interface IShape: IBase {
    CalculateArea(): f64;
}

function MakeIShape(id: String, a: f64, b: f64): IShape;

@class
interface IDerived: IShape {
    Call(): void;
}

@ctor("IDerived")
function CreateIDerived(): IDerived;
