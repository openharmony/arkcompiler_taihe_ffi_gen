interface UsedScene {
    @get("when") GetWhen(): String;
    @set("when") SetWhen(when:String);
    @get("abilities") GetAbilities(): Array<String>;
    @set("abilities") SetAbilities(abilities :Array<String>);
}
function GetUsedScene(): UsedScene;

interface ReqPermissionDetail {
    @get("name") GetName(): String;
    @set("name") SetName(name:String);
    @get("reason") GetReason(): String;
    @set("reason") SetReason(reason:String);
}
function GetReqPermissionDetail(): ReqPermissionDetail;

interface BundleInfo {
    @get("name") GetName(): String;
    @get("type") GetType(): String;
    @get("appId") GetAppId(): String;
    @get("uid") GetUid(): i32;
    @get("installTime") GetInstallTime(): i32;
    @get("updateTime") GetUpdateTime(): i32;
    @get("reqPermissions") GetReqPermissions(): Array<String>;
    @get("vendor") GetVendor(): String;
    @get("versionCode") GetVersionCode(): i32;
    @get("versionName") GetVersionName(): String;
    @get("compatibleVersion") GetCompatibleVersion(): i32;
    @get("targetVersion") GetTargetVersion(): i32;
    @get("isCompressNativeLibs") GetIsCompressNativeLibs(): bool;
    @get("entryModuleName") GetEntryModuleName(): String;
    @get("cpuAbi") GetCpuAbi(): String;
    @get("isSilentInstallation") GetIsSilentInstallation(): String;
    @get("minCompatibleVersionCode") GetMinCompatibleVersionCode(): i32;
    @get("entryInstallationFree") GetEntryInstallationFree(): bool;
    @get("reqPermissionStates") GetReqPermissionStates(): Array<i32>;
}
function GetBundleInfo(): BundleInfo;
