@class
interface Want {
    @set("bundleName") SetBundleName(bundleName: Optional<String>): void;
    @get("bundleName") GetBundleName(): Optional<String>;
    @set("abilityName") SetAbilityName(abilityName: Optional<String>): void;
    @get("abilityName") GetAbilityName(): Optional<String>;
    @set("deviceId") SetDeviceId(deviceId: Optional<String>): void;
    @get("deviceId") GetDeviceId(): Optional<String>;
    @set("uri") SetUri(uri: Optional<String>): void;
    @get("uri") GetUri(): Optional<String>;
    @set("type") SetType(type: Optional<String>): void;
    @get("type") GetType(): Optional<String>;
    @set("flags") SetFlags(flags: Optional<f64>): void;
    @get("flags") GetFlags(): Optional<f64>;
    @set("action") SetAction(action: Optional<String>): void;
    @get("action") GetAction(): Optional<String>;
    @set("parameters") SetParameters(parameters: Optional<@record Map<String, Opaque>>): void;
    @get("parameters") GetParameters(): Optional<@record Map<String, Opaque>>;
    @set("entities") SetEntities(entities: Optional<Array<String>>): void;
    @get("entities") GetEntities(): Optional<Array<String>>;
    @set("moduleName") SetModuleName(moduleName: Optional<String>): void;
    @get("moduleName") GetModuleName(): Optional<String>;
}
@ctor("Want")
function CreateWant(): Want;
