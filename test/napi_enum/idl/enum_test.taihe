enum Color: String {
    RED = "Red",
    GREEN = "Green",
    BLUE = "Blue",
}

function nextEnum(color: Color): Color;
function getValueOfEnum(color: Color): String;
function fromValueToEnum(str: String): Color;

enum Weekday: i32 {
    SUNDAY = 0,
    MONDAY,
    TUESDAY,
    WEDNESDAY,
    THURSDAY,
    FRIDAY,
    SATURDAY,
}

function nextEnumWeekday(day: Weekday): Weekday;
function getValueOfEnumWeekday(day: Weekday): i32;
function fromValueToEnumWeekday(str: i32): Weekday;

@const
enum FlagsF32: i32 {
    FLAG_F32_A = 1,
    FLAG_F32_B = 1 + 2,
}

@const
enum FlagsString: String {
    FLAG_STRING_ONE = "hello",
    FLAG_STRING_TWO = "i am boy",
    FLAG_STRING_THREE = "good morning"
}
