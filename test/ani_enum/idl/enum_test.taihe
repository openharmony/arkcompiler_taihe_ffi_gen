enum Color: String {
    RED = "Red",
    GREEN = "Green",
    BLUE = "Blue",
}

function nextEnum(color: Color): Color;
function showEnum(color: Color): void;

enum Weekday: i32 {
    MONDAY,
    TUESDAY,
    WEDNESDAY,
    THURSDAY,
    FRIDAY,
    SATURDAY,
    SUNDAY
}

function nextEnumWeekday(day: Weekday): Weekday;
function showEnumWeekday(day: Weekday): void;

@const
enum Flags: f64 {
    FLAG_F64_A = 1.0,
    FLAG_F64_B = 1.0 + 1.0,
}

enum NumTypeI8: i8 {
    ONE = -128,
    TWO = 0,
    THREE = 127
}

function nextEnumI8(numtypei8: NumTypeI8): NumTypeI8;

enum NumTypeI16: i16 {
    ONE = -32768,
    TWO = 0,
    THREE = 32767
}

function nextEnumI16(numtypei16: NumTypeI16): NumTypeI16;

enum NumTypeI32: i32 {
    ONE = -2147483648,
    TWO = 0,
    THREE = 2147483647
}

function nextEnumI32(numtypei32: NumTypeI32): NumTypeI32;

enum NumTypeI64: i64 {
    ONE = -922337203685477580,
    TWO = 0,
    THREE = 922337203685477580
}

function nextEnumI64(numtypei64: NumTypeI64): NumTypeI64;

enum EnumString: String {
    ONE = "hello",
    TWO = "i am boy",
    THREE = "good morning"
}

function nextEnumString(enumString: EnumString): EnumString;

