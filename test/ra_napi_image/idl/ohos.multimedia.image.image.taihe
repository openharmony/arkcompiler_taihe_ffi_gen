@!namespace("@ohos.multimedia.image", "image")

struct Size {
    height: i32;
    width: i32;
}

enum PixelMapFormat: i32 {
    UNKNOWN = 0,
    ARGB_8888 = 1,
    RGB_565 = 2,
    RGBA_8888 = 3,
    BGRA_8888 = 4,
    RGB_888 = 5,
    ALPHA_8 = 6,
    RGBA_F16 = 7,
    NV21 = 8,
    NV12 = 9,
    RGBA_1010102 = 10,
    YCBCR_P010 = 11,
    YCRCB_P010 = 12,
    ASTC_4x4 = 102
}

enum DecodingDynamicRange: i32 {
    AUTO = 0,
    SDR = 1,
    HDR = 2
}

enum AntiAliasingLevel: i32 {
    NONE = 0,
    LOW = 1,
    MEDIUM = 2,
    HIGH = 3
}

struct DecodingOptions {
    index: Optional<i32>;
    sampleSize: Optional<i32>;
    rotate: Optional<i32>;
    editable: Optional<bool>;
    desiredSize: Optional<Size>;
    desiredRegion: Optional<Region>;
    desiredPixelFormat: Optional<PixelMapFormat>;
    fitDensity: Optional<i32>;
    // desiredColorSpace: Optional<colorSpaceManager.ColorSpaceManager>;
    desiredDynamicRange: Optional<DecodingDynamicRange>;
}

enum AlphaType: i32 {
    UNKNOWN = 0,
    OPAQUE = 1,
    PREMUL = 2,
    UNPREMUL = 3
}

union NullableString {
    str: String;
    null: unit;
}

struct Region {
    size: Size;
    x: i32;
    y: i32;
}

interface PixelMap {
    @promise CreateAlphaPixelmapRetPromise(): PixelMap;
    @async CreateAlphaPixelmapWithAsync(): PixelMap;
    CreateAlphaPixelmapSync(): PixelMap;

    @promise GetImageInfoRetPromise(): ImageInfo;
    @async GetImageInfoAsync(): PixelMap;
    GetImageInfoSync(): ImageInfo;

    GetBytesNumberPerRow(): i32;
    GetPixelBytesNumber(): i32;

    @promise ReadPixelsToBufferRetPromise(buff: @arraybuffer Array<u8>);
    @async ReadPixelsToBufferWithAsync(): PixelMap;
    ReadPixelsToBufferSync(buff: @arraybuffer Array<u8>);

    ScaleSync(x: f64, y: f64): void;
    ScaleWithAntiAliasingSync(x: f64, y: f64, level: AntiAliasingLevel): void;

    @promise CropRetPromise(region: Region): void;
    @async CropWithAsync(): PixelMap;
    CropSync(region: Region): void;

    FlipSync(horizontal: bool, vertical: bool): void;

    @promise ReleaseRetPromise(): void;
    @async ReleaseWithAsync(): void;
    ReleaseSync(): void;

    GetImplPtr(): i64;
}

struct ImageInfo {
    size: Size;
    density: i32;
    stride: i32;
    pixelFormat: PixelMapFormat;
    alphaType: AlphaType;
    mimeType: String;
    isHdr: bool;
}

interface ImageSource {
    @promise GetImageInfoWithAsync(index: i32): ImageInfo;
    @async GetImageInfoRetPromise(index: i32): ImageInfo;
    GetImageInfoSync(index: i32): ImageInfo;

    @promise CreatePixelMapRetPromise(options: Optional<DecodingOptions>): PixelMap;
    @async CreatePixelMapWithAsync(options: Optional<DecodingOptions>): PixelMap;
    CreatePixelMapSync(options: Optional<DecodingOptions>): PixelMap;

    @promise ModifyImagePropertyRetPromise(key: String, value: String): void;
    @async ModifyImagePropertyWithAsync(key: String, value: String): void;

    @promise ModifyImagePropertiesRetPromise(records: @record Map<String, NullableString>): void;
    @promise GetImagePropertiesRetPromise(key: Array<String>): @record Map<String, NullableString>;

    @promise ReleaseRetPromise(): void;
    @async ReleaseWithAsync(): void;
}
