@class struct BaseDataClass {
    a: String;
}

struct FooDataInterface {
    p: String;
}

struct BarDataInterface {
    q: String;
}

@class struct DerivedDataClass {
    @extends base: BaseDataClass;
    @extends foo: FooDataInterface;
    @extends bar: BarDataInterface;
    x: i32;
    y: i32;
}

@class interface BaseMethodClass {
    base(): String;
}

interface FooInterface {
    foo(): String;
}

interface BarInterface {
    bar(): String;
}

@class interface DerivedMethodClass: BaseMethodClass, FooInterface, BarInterface {
    derived(): String;
}

@ctor("DerivedMethodClass")
function makeDerivedMethodClass(): DerivedMethodClass;

function makeDerivedDataClass(): DerivedDataClass;
