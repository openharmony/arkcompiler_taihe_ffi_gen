union union_primitive {
  sValue: String;
  numberValue: f64;
  bValue: bool;
  aValue: Array<i32>;
  mValue: Map<i32, String>;
  uValue: @undefined unit;
  nValue: @null unit;
}

function printUnion(data: union_primitive): String;
function makeUnion(kind: String): union_primitive;
