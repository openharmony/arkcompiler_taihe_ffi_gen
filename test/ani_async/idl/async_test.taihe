@gen_async
@gen_promise
function addSync(a: i32, b: i32): i32;

@class
interface IBase {
    @gen_async("getWithCallback")
    @gen_promise("getReturnsPromise")
    get(): String;
  
    @gen_async("setWithCallback")
    @gen_promise("setReturnsPromise")
    set(a: String): void;

    @gen_async
    @gen_promise
    makeSync();
}

@gen_async
@gen_promise
function makeGlobalSync();

function getIBase(): IBase;

@static("IBase")
@gen_async
@gen_promise
function PrintSync(): void;

struct Data {
  a: String;
  b: String;
  c: i32;
}

@gen_async
@gen_promise
function fromStructSync(data: Data): void;

@gen_async
@gen_promise
function toStructSync(a: String, b: String, c: i32): Data;
